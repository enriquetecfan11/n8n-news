---
import type { Holding } from '../../lib/portfolio';
import { formatCurrency, formatPercent } from '../../lib/portfolio';

interface Props {
  holdings: Holding[];
  totalValue: number;
}

const { holdings, totalValue } = Astro.props;

const getShortName = (name: string) => {
  const parts = name.split(' ');
  return parts.length > 1 && name.length > 18 ? parts[0] : name;
};

const safeTickerId = (ticker: string) => ticker.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<div class="holdings-container">
  <table class="holdings-table">
    <colgroup>
      <col class="col-asset" />
      <col class="col-quantity" />
      <col class="col-price" />
      <col class="col-value" />
      <col class="col-pnl" />
      <col class="col-weight" />
    </colgroup>
    <thead>
      <tr>
        <th>Activo</th>
        <th>Cantidad</th>
        <th>Precio Actual</th>
        <th>Var 24h</th>
        <th>Valor Actual</th>
        <th>P&L</th>
        <th>Peso</th>
      </tr>
    </thead>
    <tbody>
      {holdings.map((holding) => (
        <>
          <tr
            data-holding-row
            data-asset-name={holding.assetName}
            data-ticker={holding.ticker}
            data-row-id={safeTickerId(holding.ticker)}
            class="holding-row"
          >
          <td class="asset-cell">
            <div class="holding-name">
              <span class="holding-logo" aria-hidden="true">
                {holding.ticker ? holding.ticker.slice(0, 2).toUpperCase() : '•'}
              </span>
              <span class="holding-name-text" title={holding.assetName}>{getShortName(holding.assetName)}</span>
              <span class:list={['holding-badge', holding.type]}>
                {holding.ticker}
              </span>
            </div>
          </td>
          <td class="num-cell num-cell-strong">{holding.quantity.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 8 })}</td>
          <td class="num-cell">{holding.priceAvailable ? formatCurrency(holding.currentPrice, holding.currency) : <span class="muted-cell">N/D</span>}</td>
          <td class:list={['num-cell', holding.priceAvailable ? (holding.priceChange24h >= 0 ? 'pnl-positive' : 'pnl-negative') : 'muted-cell']}>
            {holding.priceAvailable ? formatPercent(holding.priceChange24h) : 'N/D'}
          </td>
          <td class="num-cell num-cell-strong">{formatCurrency(holding.currentValue, holding.currency)}</td>
          <td class:list={['num-cell', holding.pnlAbsolute >= 0 ? 'pnl-positive' : 'pnl-negative']}>
            <div class="pnl-stack">
              <span class="pnl-abs">{formatCurrency(holding.pnlAbsolute, holding.currency)}</span>
              <span class="pnl-pct">{formatPercent(holding.pnlPercent)}</span>
            </div>
          </td>
          <td class="num-cell">
            <div class="weight-cell">
              <span>
                {totalValue > 0 ? `${((holding.currentValue / totalValue) * 100).toFixed(1)}%` : '0.0%'}
              </span>
              <span class="row-toggle" aria-hidden="true">▸</span>
            </div>
          </td>
          </tr>
          <tr id={`chart-row-${safeTickerId(holding.ticker)}`} class="chart-row hidden">
            <td colspan="6" class="chart-cell">
              <div class="chart-panel">
                <div class="chart-mini-header">
                  <span class="chart-name">{holding.assetName}</span>
                  <span class="chart-ticker">{holding.ticker}</span>
                  <span class="chart-meta">
                    Valor medio {formatCurrency(holding.averagePrice, holding.currency)} · Coste total {formatCurrency(holding.totalCost, holding.currency)} · 24h {holding.priceAvailable ? formatPercent(holding.priceChange24h) : 'N/D'}
                  </span>
                </div>
                <div id={`tv-${safeTickerId(holding.ticker)}`} class="chart-widget"></div>
              </div>
            </td>
          </tr>
        </>
      ))}
    </tbody>
  </table>
  {holdings.length === 0 && (
    <div class="empty-table">
      No hay activos en el portafolio
    </div>
  )}
</div>

<style>
  .holdings-container {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-2xl);
    overflow: auto;
  }

  .holdings-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .holdings-table thead {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border-bottom: 1px solid var(--pf-border);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .holdings-table th {
    padding: 0.55rem 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--pf-card);
  }

  .holdings-table td {
    padding: 0.48rem 0.75rem;
    border-bottom: 1px solid var(--pf-border);
    color: var(--pf-text);
    vertical-align: middle;
  }

  .holdings-table tbody tr {
    background: transparent;
  }

  .holding-row {
    cursor: pointer;
    transition: background-color 0.16s ease;
  }

  .holding-row:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .holding-row.is-open {
    background: rgba(255, 255, 255, 0.04);
  }

  .holdings-table thead th:first-child,
  .holding-row td:first-child {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--pf-card);
  }

  .holdings-table thead th:first-child {
    z-index: 3;
  }

  .asset-cell {
    min-width: 260px;
  }

  .chart-row {
    background: transparent;
  }

  .chart-row.hidden {
    display: none;
  }

  .chart-cell {
    padding: 0;
  }

  .chart-panel {
    padding: 0.75rem 0.75rem 0.9rem;
  }

  .chart-mini-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .chart-name {
    color: var(--pf-text);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .chart-ticker {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    color: #818cf8;
  }

  .chart-meta {
    margin-left: auto;
    color: var(--pf-text-muted);
    font-size: 0.75rem;
  }

  .chart-widget {
    height: 260px;
    width: 100%;
  }

  .weight-cell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .row-toggle {
    color: #64748b;
    transition: transform 0.2s ease;
    font-size: 0.9rem;
    line-height: 1;
  }

  .holding-row.is-open .row-toggle {
    transform: rotate(90deg);
  }

  .muted-cell {
    color: var(--pf-text-muted);
  }

  .holding-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .holding-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.45rem;
    height: 1.45rem;
    border-radius: 0.45rem;
    background: rgba(99, 102, 241, 0.12);
    color: #c7d2fe;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .holding-name-text {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 180px;
  }

  .holding-badge {
    display: inline-block;
    padding: 0.18rem 0.45rem;
    border-radius: var(--radius-md);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .holding-badge.stock {
    background: rgba(37, 99, 235, 0.08);
    color: #1d4ed8;
  }

  .holding-badge.etf {
    background: rgba(16, 185, 129, 0.08);
    color: #047857;
  }

  .holding-badge.crypto {
    background: rgba(245, 158, 11, 0.1);
    color: #b45309;
  }

  .holding-badge.cash {
    background: rgba(100, 116, 139, 0.08);
    color: #475569;
  }

  .pnl-positive {
    color: rgba(34, 197, 94, 0.92);
    font-weight: 600;
  }

  .pnl-negative {
    color: rgba(239, 68, 68, 0.92);
    font-weight: 600;
  }

  .num-cell {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .num-cell-strong {
    font-weight: 700;
  }

  .pnl-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1.05;
  }

  .pnl-abs {
    font-weight: 700;
  }

  .pnl-pct {
    margin-top: 0.08rem;
    font-size: 0.72rem;
    color: inherit;
    opacity: 0.8;
  }

  .empty-table {
    padding: 1.5rem;
    text-align: center;
    color: var(--pf-text-muted);
  }

  @media (max-width: 768px) {
    .holdings-table {
      font-size: 0.875rem;
    }

    .holdings-table th,
    .holdings-table td {
      padding: 0.5rem 0.65rem;
    }

    .holding-name-text {
      max-width: 120px;
    }

    .asset-cell {
      min-width: 220px;
    }
  }
</style>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
  const initHoldingsCharts = () => {
    const rows = Array.from(document.querySelectorAll('[data-holding-row]'));
    const state = new Map();
    let openRowId = null;

    const closeRow = (rowId) => {
      const row = document.querySelector(`#chart-row-${CSS.escape(rowId)}`);
      const holdingRow = document.querySelector(`[data-row-id="${rowId}"]`);
      if (row) row.classList.add('hidden');
      if (holdingRow) holdingRow.classList.remove('is-open');
      if (openRowId === rowId) openRowId = null;
    };

    const openRow = (rowId, ticker, assetName) => {
      const row = document.querySelector(`#chart-row-${CSS.escape(rowId)}`);
      const holdingRow = document.querySelector(`[data-row-id="${rowId}"]`);
      const chartEl = document.getElementById(`tv-${rowId}`);
      if (!row || !holdingRow || !chartEl) return;

      row.classList.remove('hidden');
      holdingRow.classList.add('is-open');
      openRowId = rowId;

      if (!state.get(rowId) && window.TradingView) {
        chartEl.innerHTML = '';
        new window.TradingView.widget({
          container_id: `tv-${rowId}`,
          symbol: ticker,
          interval: '15',
          theme: 'dark',
          style: '1',
          locale: 'es',
          toolbar_bg: '#0f1117',
          backgroundColor: 'rgba(0,0,0,0)',
          enable_publishing: false,
          hide_side_toolbar: true,
          allow_symbol_change: false,
          height: 300,
          width: '100%',
        });
        state.set(rowId, true);
      }
    };

    rows.forEach((row) => {
      row.addEventListener('click', () => {
        const rowId = row.getAttribute('data-row-id') || '';
        const ticker = row.getAttribute('data-ticker') || '';
        const assetName = row.getAttribute('data-asset-name') || '';
        if (!rowId || !ticker) return;

        if (openRowId === rowId) {
          closeRow(rowId);
          return;
        }

        if (openRowId) closeRow(openRowId);
        openRow(rowId, ticker, assetName);
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHoldingsCharts);
  } else {
    initHoldingsCharts();
  }
</script>
