---
import type { Holding } from '../../lib/portfolio';
import { formatCurrency, formatPercent } from '../../lib/portfolio';

interface Props {
  holdings: Holding[];
  totalValue: number;
}

const { holdings, totalValue } = Astro.props;

const getShortName = (name: string) => {
  const parts = name.split(' ');
  return parts.length > 1 && name.length > 18 ? parts[0] : name;
};

const safeTickerId = (ticker: string) => ticker.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<div class="holdings-container">
  <table class="holdings-table">
    <thead>
      <tr>
        <th>Activo</th>
        <th>Cantidad</th>
        <th>Precio Medio</th>
        <th>Coste Total</th>
        <th>Precio Actual</th>
        <th>Var 24h</th>
        <th>Valor Actual</th>
        <th>P&L Absoluto</th>
        <th>P&L %</th>
        <th>Peso</th>
      </tr>
    </thead>
    <tbody>
      {holdings.map((holding) => (
        <>
          <tr
            data-holding-row
            data-asset-name={holding.assetName}
            data-ticker={holding.ticker}
            data-row-id={safeTickerId(holding.ticker)}
            class="holding-row"
          >
          <td style="color: #ffffff">
            <div class="holding-name">
              <span class="holding-name-text" title={holding.assetName}>{getShortName(holding.assetName)}</span>
              <span class:list={['holding-badge', holding.type]}>
                {holding.ticker}
              </span>
            </div>
          </td>
          <td style="color: #ffffff">{holding.quantity.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 8 })}</td>
          <td style="color: #ffffff">{formatCurrency(holding.averagePrice, holding.currency)}</td>
          <td style="color: #ffffff">{formatCurrency(holding.quantity * holding.averagePrice, holding.currency)}</td>
          <td style="color: #ffffff">{holding.priceAvailable ? formatCurrency(holding.currentPrice, holding.currency) : <span class="muted-cell">N/D</span>}</td>
          <td style="color: #ffffff" class:list={holding.priceAvailable ? [holding.priceChange24h >= 0 ? 'pnl-positive' : 'pnl-negative'] : ['muted-cell']}>
            {holding.priceAvailable ? `${holding.priceChange24h >= 0 ? '↑' : '↓'} ${formatPercent(Math.abs(holding.priceChange24h))}` : 'N/D'}
          </td>
          <td style="color: #ffffff">{formatCurrency(holding.currentValue, holding.currency)}</td>
          <td style="color: #ffffff" class:list={[holding.pnlAbsolute >= 0 ? 'pnl-positive' : 'pnl-negative']}>
            {formatCurrency(holding.pnlAbsolute, holding.currency)}
          </td>
          <td style="color: #ffffff" class:list={[holding.pnlPercent >= 0 ? 'pnl-positive' : 'pnl-negative']}>
            {formatPercent(holding.pnlPercent)}
          </td>
          <td style="color: #ffffff">
            <div class="weight-cell">
              <span>
                {totalValue > 0 ? `${((holding.currentValue / totalValue) * 100).toFixed(1)}%` : '0.0%'}
              </span>
              <span class="row-toggle" aria-hidden="true">▸</span>
            </div>
          </td>
          </tr>
          <tr id={`chart-row-${safeTickerId(holding.ticker)}`} class="chart-row hidden">
            <td colspan="10" class="chart-cell">
              <div class="chart-panel">
                <div class="chart-mini-header">
                  <span class="chart-name">{holding.assetName}</span>
                  <span class="chart-ticker">{holding.ticker}</span>
                  <span class="chart-meta">Gráfico diario · TradingView</span>
                </div>
                <div id={`tv-${safeTickerId(holding.ticker)}`} class="chart-widget"></div>
              </div>
            </td>
          </tr>
        </>
      ))}
    </tbody>
  </table>
  {holdings.length === 0 && (
    <div class="empty-table">
      No hay activos en el portafolio
    </div>
  )}
</div>

<style>
  .holdings-container {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-2xl);
    overflow: auto;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .holdings-table {
    width: 100%;
    border-collapse: collapse;
  }

  .holdings-table thead {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border-bottom: 1px solid var(--pf-border);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .holdings-table th {
    padding: var(--pf-table-cell-pad-y) var(--pf-table-cell-pad-x);
    text-align: left;
    font-weight: 600;
    font-size: 0.7rem;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .holdings-table td {
    padding: var(--pf-table-cell-pad-y) var(--pf-table-cell-pad-x);
    border-bottom: 1px solid var(--pf-border);
    color: #ffffff;
    vertical-align: middle;
  }

  .holdings-table tbody tr {
    background: transparent;
    border-bottom: 1px solid #2a2d3a;
  }

  .holding-row {
    cursor: pointer;
  }

  .chart-row {
    background: #1e2433;
  }

  .chart-row.hidden {
    display: none;
  }

  .chart-cell {
    padding: 0;
    border-bottom: 1px solid #2a2d3a;
  }

  .chart-panel {
    padding: 1rem;
    background: #1e2433;
    border-top: 1px solid #2a2d3a;
  }

  .chart-mini-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .chart-name {
    color: #ffffff;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .chart-ticker {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
  }

  .chart-meta {
    margin-left: auto;
    color: #64748b;
    font-size: 0.75rem;
  }

  .chart-widget {
    height: 300px;
    width: 100%;
  }

  .weight-cell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .row-toggle {
    color: #64748b;
    transition: transform 0.2s ease;
    font-size: 0.9rem;
    line-height: 1;
  }

  .holding-row.is-open .row-toggle {
    transform: rotate(90deg);
  }

  .muted-cell {
    color: #94a3b8;
  }

  .holding-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .holding-name-text {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 180px;
  }

  .holding-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-md);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .holding-badge.stock {
    background: rgba(37, 99, 235, 0.08);
    color: #1d4ed8;
  }

  .holding-badge.etf {
    background: rgba(16, 185, 129, 0.08);
    color: #047857;
  }

  .holding-badge.crypto {
    background: rgba(245, 158, 11, 0.1);
    color: #b45309;
  }

  .holding-badge.cash {
    background: rgba(100, 116, 139, 0.08);
    color: #475569;
  }

  .pnl-positive {
    color: #15803d;
    font-weight: 600;
  }

  .pnl-negative {
    color: #b91c1c;
    font-weight: 600;
  }

  .empty-table {
    padding: 1.5rem;
    text-align: center;
    color: var(--pf-text-muted);
  }

  @media (max-width: 768px) {
    .holdings-table {
      font-size: 0.875rem;
    }

    .holdings-table th,
    .holdings-table td {
      padding: 0.5rem 0.65rem;
    }

    .holding-name-text {
      max-width: 120px;
    }
  }
</style>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
  const initHoldingsCharts = () => {
    const rows = Array.from(document.querySelectorAll('[data-holding-row]'));
    const state = new Map();
    let openRowId = null;

    const closeRow = (rowId) => {
      const row = document.querySelector(`#chart-row-${CSS.escape(rowId)}`);
      const holdingRow = document.querySelector(`[data-row-id="${rowId}"]`);
      if (row) row.classList.add('hidden');
      if (holdingRow) holdingRow.classList.remove('is-open');
      if (openRowId === rowId) openRowId = null;
    };

    const openRow = (rowId, ticker, assetName) => {
      const row = document.querySelector(`#chart-row-${CSS.escape(rowId)}`);
      const holdingRow = document.querySelector(`[data-row-id="${rowId}"]`);
      const chartEl = document.getElementById(`tv-${rowId}`);
      if (!row || !holdingRow || !chartEl) return;

      row.classList.remove('hidden');
      holdingRow.classList.add('is-open');
      openRowId = rowId;

      if (!state.get(rowId) && window.TradingView) {
        chartEl.innerHTML = '';
        new window.TradingView.widget({
          container_id: `tv-${rowId}`,
          symbol: ticker,
          interval: '15',
          theme: 'dark',
          style: '1',
          locale: 'es',
          toolbar_bg: '#0f1117',
          backgroundColor: 'rgba(0,0,0,0)',
          enable_publishing: false,
          hide_side_toolbar: true,
          allow_symbol_change: false,
          height: 300,
          width: '100%',
        });
        state.set(rowId, true);
      }
    };

    rows.forEach((row) => {
      row.addEventListener('click', () => {
        const rowId = row.getAttribute('data-row-id') || '';
        const ticker = row.getAttribute('data-ticker') || '';
        const assetName = row.getAttribute('data-asset-name') || '';
        if (!rowId || !ticker) return;

        if (openRowId === rowId) {
          closeRow(rowId);
          return;
        }

        if (openRowId) closeRow(openRowId);
        openRow(rowId, ticker, assetName);
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHoldingsCharts);
  } else {
    initHoldingsCharts();
  }
</script>
