---
interface Props {
  baseCurrency: string;
  portfolioId: string;
}

const { baseCurrency, portfolioId } = Astro.props;
---

<div class="toolbar">
  <div class="toolbar-section">
    <span class="currency-badge">{baseCurrency}</span>
  </div>

  <div class="toolbar-section toolbar-section--actions">
    <button class="btn btn-icon btn-primary" onclick="document.getElementById('modal-comprar-activo').classList.remove('hidden')" title="Comprar activo">
      <span class="btn-icon-symbol">💳</span>
      <span class="btn-label">Comprar Activo</span>
    </button>
  </div>

  <div class="toolbar-section toolbar-section--utilities">
    <details class="toolbar-menu">
      <summary class="btn btn-icon btn-secondary toolbar-menu-trigger" title="Más acciones">
        <span class="btn-icon-symbol">⋯</span>
        <span class="btn-label">Acciones</span>
      </summary>
      <div class="toolbar-menu-panel">
        <button class="toolbar-menu-item" data-open-import-modal title="Importar transacciones desde CSV">
          <span>📥</span>
          <span>Importar</span>
        </button>
        <button class="toolbar-menu-item" data-refresh-prices title="Actualizar precios actuales">
          <span>🔄</span>
          <span>Actualizar</span>
        </button>
        <button class="toolbar-menu-item" data-open-edit-portfolio-modal title="Editar información del portafolio">
          <span>✎</span>
          <span>Editar</span>
        </button>
        <button class="toolbar-menu-item toolbar-menu-item--danger" data-delete-portfolio data-portfolio-id={portfolioId} title="Eliminar portafolio permanentemente">
          <span>🗑️</span>
          <span>Eliminar</span>
        </button>
      </div>
    </details>
  </div>
</div>

<style>
  .toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--pf-card-pad);
    margin-bottom: var(--pf-section-gap);
    background: var(--pf-toolbar-bg);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-2xl);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    flex-wrap: wrap;
  }

  .toolbar-section {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toolbar-section--actions,
  .toolbar-section--utilities {
    padding: 0;
  }

  .currency-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 30px;
    padding: 0 0.5rem;
    background: linear-gradient(135deg, #111827 0%, #334155 100%);
    border-radius: var(--radius-lg);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: white;
    border: none;
    text-transform: uppercase;
  }

  /* Button Base Styles */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: var(--pf-control-pad-y) var(--pf-control-pad-x);
    border: none;
    border-radius: var(--radius-lg);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .btn-icon {
    min-height: 30px;
  }

  .btn-icon-symbol {
    font-size: 0.95rem;
    line-height: 1;
  }

  .btn-label {
    font-weight: 600;
    font-size: 0.78rem;
  }

  /* Primary - For adding/creating actions */
  .btn-primary {
    background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
    color: white;
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.16);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #111827 0%, #1d4ed8 100%);
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(37, 99, 235, 0.2);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  /* Secondary - For utility actions */
  .btn-secondary {
    background: #ffffff;
    color: var(--pf-text-muted);
    border: 1px solid var(--pf-border);
  }

  .btn-secondary:hover {
    background: #f8fafc;
    color: var(--pf-text);
    border-color: #cbd5e1;
  }

  .toolbar-menu {
    position: relative;
  }

  .toolbar-menu summary {
    list-style: none;
  }

  .toolbar-menu summary::-webkit-details-marker {
    display: none;
  }

  .toolbar-menu-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 190px;
    padding: 0.3rem;
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    background: #ffffff;
    box-shadow: 0 16px 36px rgba(15, 23, 42, 0.12);
    z-index: 20;
  }

  .toolbar-menu-item {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.65rem;
    border: none;
    background: transparent;
    color: var(--pf-text);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    cursor: pointer;
    text-align: left;
  }

  .toolbar-menu-item:hover {
    background: #f8fafc;
  }

  .toolbar-menu-item--danger {
    color: #b91c1c;
  }

  .toolbar-menu-item--danger:hover {
    background: rgba(239, 68, 68, 0.08);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .toolbar {
      padding: 0.55rem 0.65rem;
      gap: var(--space-xs);
    }

    .toolbar-section {
      gap: var(--space-xs);
    }

    .toolbar-section--actions,
    .toolbar-section--utilities {
      padding: 0;
    }

    .btn {
      padding: 0.35rem 0.5rem;
    }

    .btn-label {
      display: none;
    }

    .currency-badge {
      min-width: 40px;
      height: 28px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .toolbar {
      flex-direction: column;
      gap: 0.45rem;
    }

    .toolbar-section {
      width: 100%;
      justify-content: space-around;
    }

    .toolbar-menu-panel {
      left: 0;
      right: auto;
    }
  }
</style>
