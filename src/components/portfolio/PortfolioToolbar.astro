---
interface Props {
  baseCurrency: string;
  portfolioId: string;
}

const { baseCurrency, portfolioId } = Astro.props;
---

<div class="toolbar">
  <div class="toolbar-section">
    <span class="currency-badge">{baseCurrency}</span>
  </div>

  <div class="toolbar-divider"></div>

  <div class="toolbar-section toolbar-section--actions">
    <button class="btn btn-icon btn-primary" onclick="document.getElementById('modal-comprar-activo').classList.remove('hidden')" title="Comprar activo">
      <span class="btn-icon-symbol">💳</span>
      <span class="btn-label">Comprar Activo</span>
    </button>
  </div>

  <div class="toolbar-divider"></div>

  <div class="toolbar-section toolbar-section--utilities">
    <button class="btn btn-icon btn-secondary" data-open-import-modal title="Importar transacciones desde CSV">
      <span class="btn-icon-symbol">📥</span>
      <span class="btn-label">Importar</span>
    </button>
    <button class="btn btn-icon btn-secondary" data-refresh-prices title="Actualizar precios actuales">
      <span class="btn-icon-symbol">🔄</span>
      <span class="btn-label">Actualizar</span>
    </button>
    <button class="btn btn-icon btn-secondary" data-open-edit-portfolio-modal title="Editar información del portafolio">
      <span class="btn-icon-symbol">✎</span>
      <span class="btn-label">Editar</span>
    </button>
  </div>

  <div class="toolbar-divider"></div>

  <div class="toolbar-section toolbar-section--destructive">
    <button class="btn btn-icon btn-danger" data-delete-portfolio data-portfolio-id={portfolioId} title="Eliminar portafolio permanentemente">
      <span class="btn-icon-symbol">🗑️</span>
      <span class="btn-label">Eliminar</span>
    </button>
  </div>
</div>

<style>
  .toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-2xl);
    background: var(--pf-toolbar-bg);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    flex-wrap: wrap;
  }

  .toolbar-section {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .toolbar-section--actions,
  .toolbar-section--utilities {
    padding: 0;
  }

  .toolbar-divider {
    width: 1px;
    height: 28px;
    background: linear-gradient(180deg, transparent, #3d4459, transparent);
    margin: 0;
    flex-shrink: 0;
  }

  .currency-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    height: 36px;
    padding: 0 var(--space-md);
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    border-radius: var(--radius-lg);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.75px;
    color: white;
    border: none;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.35);
  }

  /* Button Base Styles */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    border: none;
    border-radius: var(--radius-lg);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .btn-icon {
    min-height: 36px;
  }

  .btn-icon-symbol {
    font-size: 0.95rem;
    line-height: 1;
  }

  .btn-label {
    font-weight: 600;
    font-size: 0.8125rem;
  }

  /* Primary - For adding/creating actions */
  .btn-primary {
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: white;
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.25);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  /* Secondary - For utility actions */
  .btn-secondary {
    background: var(--pf-stat-bg);
    color: var(--pf-text-muted);
    border: 1px solid var(--pf-border);
  }

  .btn-secondary:hover {
    background: rgba(99, 102, 241, 0.12);
    color: var(--pf-text);
    border-color: rgba(99, 102, 241, 0.5);
  }

  /* Danger - For destructive actions */
  .btn-danger {
    background: var(--pf-stat-bg);
    color: #f87171;
    border: 1px solid var(--pf-border);
  }

  .btn-danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #fca5a5;
    border-color: rgba(239, 68, 68, 0.4);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .toolbar {
      padding: var(--space-sm) var(--space-md);
      gap: var(--space-xs);
    }

    .toolbar-section {
      gap: var(--space-xs);
    }

    .toolbar-section--actions,
    .toolbar-section--utilities {
      padding: 0 var(--space-sm);
    }

    .toolbar-divider {
      height: 20px;
    }

    .btn {
      padding: var(--space-xs) var(--space-xs);
    }

    .btn-label {
      display: none;
    }

    .currency-badge {
      min-width: 40px;
      height: 28px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .toolbar {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .toolbar-divider {
      display: none;
    }

    .toolbar-section {
      width: 100%;
      justify-content: space-around;
    }
  }
</style>
