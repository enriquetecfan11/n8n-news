---
import Modal from '../Modal.astro';

interface Props {
  portfolioId?: string;
  portfolioName?: string;
  portfolioDescription?: string;
  portfolioCurrency?: string;
}

const { portfolioId, portfolioName, portfolioDescription, portfolioCurrency } = Astro.props;
---

<Modal
  id="edit-portfolio-modal"
  title="Editar Portafolio"
  subtitle="Actualiza los detalles de tu portafolio"
>
  <form id="edit-portfolio-form">
    <input type="hidden" name="portfolioId" value={portfolioId} />

    <div class="form-group">
      <label for="edit-name" class="form-label">
        <span class="form-label-text">Nombre del Portafolio</span>
        <span class="form-label-required">*</span>
      </label>
      <input
        id="edit-name"
        type="text"
        name="name"
        class="w-full bg-[#2a3347] text-white rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        value={portfolioName}
        required
      />
    </div>

    <div class="form-group">
      <label for="edit-description" class="form-label">
        <span class="form-label-text">Descripción</span>
        <span class="form-label-optional">(opcional)</span>
      </label>
      <textarea
        id="edit-description"
        name="description"
        class="w-full bg-[#2a3347] text-white rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
        rows="3"
      >{portfolioDescription}</textarea>
      <span class="form-hint">Actualiza las notas sobre la estrategia de este portafolio</span>
    </div>

    <div class="form-group">
      <label for="edit-currency" class="form-label">
        <span class="form-label-text">Divisa Base</span>
      </label>
      <select
        id="edit-currency"
        name="baseCurrency"
        class="w-full bg-[#2a3347] text-white rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
      >
        <option value="EUR" selected={portfolioCurrency === 'EUR'}>EUR (€ Euros)</option>
        <option value="USD" selected={portfolioCurrency === 'USD'}>USD ($ Dólares)</option>
        <option value="GBP" selected={portfolioCurrency === 'GBP'}>GBP (£ Libras)</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="button" class="btn btn-secondary modal-cancel">Cancelar</button>
      <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    </div>
  </form>

  <div id="edit-portfolio-status" class="form-status"></div>
</Modal>

<script>
  function initEditPortfolioModal() {
    const modal = document.getElementById('edit-portfolio-modal');
    const form = document.getElementById('edit-portfolio-form');
    const statusDiv = document.getElementById('edit-portfolio-status');
    const openBtn = document.querySelector('[data-open-edit-portfolio-modal]');

    if (!modal || !form) return;

    const closeModal = () => {
      modal.classList.add('hidden');
      if (statusDiv) {
        statusDiv.textContent = '';
        statusDiv.className = 'form-status';
      }
    };

    openBtn?.addEventListener('click', () => {
      modal.classList.remove('hidden');
    });

    modal.querySelector('.modal-cancel')?.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {
        id: formData.get('portfolioId'),
        name: formData.get('name'),
        description: formData.get('description'),
        baseCurrency: formData.get('baseCurrency'),
      };

      try {
        if (statusDiv) {
          statusDiv.textContent = 'Guardando cambios...';
          statusDiv.className = 'form-status info';
        }

        const response = await fetch('/api/portfolio/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Error desconocido');
        }

        if (statusDiv) {
          statusDiv.textContent = '✓ Portafolio actualizado correctamente. Recargando...';
          statusDiv.className = 'form-status success';
        }

        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } catch (error) {
        if (statusDiv) {
          statusDiv.textContent = `✗ ${error instanceof Error ? error.message : 'Error al guardar'}`;
          statusDiv.className = 'form-status error';
        }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEditPortfolioModal);
  } else {
    initEditPortfolioModal();
  }
</script>

<style>
  .form-label {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }
</style>
