---
import Modal from '../Modal.astro';
---

<Modal id="modal-nuevo-portfolio" title="Crear Portafolio">
  <form id="portfolio-form" class="space-y-4">
    <div>
      <label for="portfolio-name" class="block text-sm font-medium text-slate-300 mb-1.5">
        Nombre <span class="text-red-500">*</span>
      </label>
      <input
        id="portfolio-name"
        type="text"
        name="name"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="Mi Portafolio"
        required
      />
    </div>

    <div>
      <label for="portfolio-description" class="block text-sm font-medium text-slate-300 mb-1.5">
        Descripción
      </label>
      <textarea
        id="portfolio-description"
        name="description"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
        placeholder="Describe tu estrategia..."
        rows="3"
      ></textarea>
      <span class="text-xs text-[#6b7a99] mt-1">Opcional</span>
    </div>

    <div>
      <label for="portfolio-currency" class="block text-sm font-medium text-slate-300 mb-1.5">
        Divisa Base <span class="text-red-500">*</span>
      </label>
      <select
        id="portfolio-currency"
        name="baseCurrency"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        required
      >
        <option value="EUR">EUR (€)</option>
        <option value="USD">USD ($)</option>
      </select>
    </div>

    <button
      type="submit"
      class="w-full mt-6 bg-blue-500 hover:bg-blue-400 text-white font-semibold rounded-xl px-6 py-3 transition-colors"
    >
      Crear Portafolio
    </button>
  </form>

  <div id="portfolio-status" class="hidden mt-4 p-3 rounded-lg text-sm font-medium"></div>
</Modal>

<script>
  function initPortfolioModal() {
    const modal = document.getElementById('modal-nuevo-portfolio');
    const form = document.getElementById('portfolio-form');
    const statusDiv = document.getElementById('portfolio-status');

    if (!modal || !form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        description: formData.get('description'),
        baseCurrency: formData.get('baseCurrency'),
      };

      try {
        statusDiv.textContent = 'Creando portafolio...';
        statusDiv.className = '';

        const response = await fetch('/api/portfolio/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Error desconocido');
        }

        statusDiv.textContent = '✓ Portafolio creado. Recargando...';
        statusDiv.className = 'show-success';

        setTimeout(() => {
          window.location.href = '/portfolio';
        }, 1500);
      } catch (error) {
        statusDiv.textContent = `✗ ${error instanceof Error ? error.message : 'Error'}`;
        statusDiv.className = 'show-error';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolioModal);
  } else {
    initPortfolioModal();
  }
</script>

<style>
  #portfolio-status.show-error {
    display: block !important;
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  #portfolio-status.show-success {
    display: block !important;
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
</style>
