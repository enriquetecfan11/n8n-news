---
import Modal from '../Modal.astro';

interface Props {
  portfolioId?: string;
}

const { portfolioId } = Astro.props;
---

<Modal
  id="import-transactions-modal"
  title="Importar Transacciones"
  subtitle="Carga múltiples transacciones desde un archivo CSV"
  wide={true}
>
  <div class="import-info">
    <div class="import-info-header">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 6V10M10 14H10.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p>Sube un archivo CSV con las columnas requeridas</p>
    </div>
    <ul class="csv-columns">
      <li><code>date</code> - Fecha en formato <strong>YYYY-MM-DD</strong></li>
      <li><code>type</code> - Tipo de transacción: <strong>buy</strong>, <strong>sell</strong>, <strong>dividend</strong>, <strong>fee</strong></li>
      <li><code>ticker</code> - Símbolo del activo (ej: <strong>AAPL</strong>, <strong>BTC</strong>)</li>
      <li><code>quantity</code> - Cantidad de unidades</li>
      <li><code>unitPrice</code> - Precio por unidad</li>
      <li><code>fee</code> - Comisión <span class="optional">(opcional)</span></li>
      <li><code>notes</code> - Notas adicionales <span class="optional">(opcional)</span></li>
    </ul>
  </div>

  <form id="import-transactions-form">
    <div class="form-group">
      <label for="csv-file" class="form-label">
        <span class="form-label-text">Selecciona un archivo CSV</span>
        <span class="form-label-required">*</span>
      </label>
      <div class="file-input-wrapper">
        <input
          id="csv-file"
          type="file"
          name="file"
          accept=".csv"
          class="file-input"
          required
        />
        <div class="file-input-placeholder">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 2V22M2 12H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <p>Arrastra tu archivo CSV aquí o haz clic para seleccionar</p>
        </div>
      </div>
    </div>

    <div class="preview-section" id="preview-section" style="display: none;">
      <h3>Vista Previa</h3>
      <div class="preview-table-wrapper">
        <table class="preview-table">
          <thead>
            <tr id="preview-header"></tr>
          </thead>
          <tbody id="preview-body"></tbody>
        </table>
      </div>
      <p class="preview-count"><span id="preview-count">0</span> transacciones a importar</p>
    </div>

    <div class="form-actions">
      <button type="button" class="btn btn-secondary modal-cancel">Cancelar</button>
      <button type="submit" class="btn btn-primary" id="import-submit">Importar</button>
    </div>
  </form>

  <div id="import-status" class="form-status"></div>
</Modal>

<style>
  .form-label {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .import-info {
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }

  .import-info-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .import-info-header svg {
    flex-shrink: 0;
    color: #6366f1;
  }

  .import-info-header p {
    margin: 0;
    color: var(--pf-text);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .csv-columns {
    margin: 0;
    padding-left: 1.5rem;
    list-style: disc;
    color: var(--pf-text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .csv-columns li {
    margin-bottom: 0.35rem;
  }

  .csv-columns code {
    background: rgba(99, 102, 241, 0.12);
    color: #6366f1;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: var(--font-family-mono);
    font-weight: 600;
    font-size: 0.8rem;
  }

  .csv-columns strong {
    color: var(--pf-text);
    font-weight: 600;
  }

  .csv-columns .optional {
    color: var(--pf-text-muted);
    font-size: 0.8rem;
    font-style: italic;
  }

  .file-input-wrapper {
    position: relative;
  }

  .file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    z-index: 1;
  }

  .file-input-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    border: 2px dashed var(--pf-border);
    border-radius: 0.75rem;
    background: var(--pf-stat-bg);
    cursor: pointer;
    transition: all 0.2s ease;
    gap: 0.75rem;
  }

  .file-input:hover ~ .file-input-placeholder,
  .file-input:focus ~ .file-input-placeholder {
    border-color: #6366f1;
    background: rgba(99, 102, 241, 0.08);
  }

  .file-input-placeholder svg {
    color: var(--pf-text-muted);
  }

  .file-input-placeholder p {
    margin: 0;
    color: var(--pf-text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  .preview-section h3 {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .preview-table-wrapper {
    background: var(--pf-stat-bg);
    border: 1px solid var(--pf-border);
    border-radius: 0.75rem;
    overflow: auto;
    margin-bottom: 0.75rem;
    max-height: 300px;
  }

  .preview-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .preview-table thead {
    background: rgba(99, 102, 241, 0.1);
    position: sticky;
    top: 0;
  }

  .preview-table th,
  .preview-table td {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--pf-border);
    color: var(--pf-text);
  }

  .preview-table th {
    font-weight: 600;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
  }

  .preview-count {
    margin: 0;
    font-size: 0.85rem;
    color: var(--pf-text-muted);
    font-weight: 500;
  }
</style>

<script define:vars={{ portfolioId }}>
  function initImportTransactionsModal() {
    const modal = document.getElementById('import-transactions-modal');
    const form = document.getElementById('import-transactions-form');
    const fileInput = document.getElementById('csv-file');
    const previewSection = document.getElementById('preview-section');
    const previewHeader = document.getElementById('preview-header');
    const previewBody = document.getElementById('preview-body');
    const previewCount = document.getElementById('preview-count');
    const statusDiv = document.getElementById('import-status');
    const submitBtn = document.getElementById('import-submit');

    if (!modal || !form) return;

    const closeModal = () => {
      modal.classList.add('hidden');
      form.reset();
      if (previewSection) previewSection.style.display = 'none';
      if (statusDiv) {
        statusDiv.textContent = '';
        statusDiv.className = 'form-status';
      }
    };

    modal.querySelector('.modal-cancel')?.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    fileInput?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (event) => {
        try {
          const csv = event.target?.result;
          if (typeof csv !== 'string') return;

          const lines = csv.trim().split('\n');
          if (lines.length < 2) {
            if (statusDiv) {
              statusDiv.textContent = '✗ El archivo CSV debe tener encabezados y al menos una fila de datos';
              statusDiv.className = 'form-status error';
            }
            return;
          }

          const headers = lines[0].split(',').map((h) => h.trim().toLowerCase());
          const rows = lines.slice(1).map((line) => line.split(',').map((v) => v.trim()));

          if (previewHeader) {
            previewHeader.innerHTML = headers.map((h) => `<th>${h}</th>`).join('');
          }
          if (previewBody) {
            previewBody.innerHTML = rows
              .slice(0, 5)
              .map((row) => `<tr>${row.map((v) => `<td>${v || '-'}</td>`).join('')}</tr>`)
              .join('');
          }
          if (previewCount) previewCount.textContent = String(rows.length);
          if (previewSection) previewSection.style.display = 'block';
          if (statusDiv) {
            statusDiv.textContent = '';
            statusDiv.className = 'form-status';
          }
        } catch {
          if (statusDiv) {
            statusDiv.textContent = '✗ Error al leer el archivo CSV';
            statusDiv.className = 'form-status error';
          }
        }
      };
      reader.readAsText(file);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const file = fileInput?.files?.[0];
      if (!file || !submitBtn) return;

      try {
        submitBtn.disabled = true;
        if (statusDiv) {
          statusDiv.textContent = 'Procesando archivo...';
          statusDiv.className = 'form-status info';
        }

        const formData = new FormData();
        formData.append('file', file);
        formData.append('portfolioId', portfolioId || '');

        const response = await fetch('/api/transaction/import-csv', {
          method: 'POST',
          body: formData,
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Error desconocido');
        }

        const result = await response.json();
        if (statusDiv) {
          statusDiv.textContent = `✓ ${result.count} transacciones importadas correctamente. Recargando...`;
          statusDiv.className = 'form-status success';
        }

        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } catch (error) {
        submitBtn.disabled = false;
        if (statusDiv) {
          statusDiv.textContent = `✗ ${error instanceof Error ? error.message : 'Error'}`;
          statusDiv.className = 'form-status error';
        }
      }
    });

    window.openImportTransactionsModal = () => {
      modal.classList.remove('hidden');
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImportTransactionsModal);
  } else {
    initImportTransactionsModal();
  }
</script>
