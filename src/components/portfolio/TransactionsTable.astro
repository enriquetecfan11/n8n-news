---
import type { Transaction, Asset } from '../../lib/portfolio';
import { formatCurrency } from '../../lib/portfolio';

interface Props {
  transactions: Transaction[];
  assets: Map<string, Asset>;
  averageCostByAsset?: Map<string, number>;
  limit?: number;
  showDelete?: boolean;
}

const { transactions, assets, averageCostByAsset = new Map(), limit, showDelete = false } = Astro.props;
const displayTransactions = limit ? transactions.slice(0, limit) : transactions;

const typeLabels: Record<string, string> = {
  buy: 'Compra',
  sell: 'Venta',
  dividend: 'Dividendo',
  fee: 'Comisión',
};

const getTypeClass = (type: string) => {
  if (type === 'buy') return 'buy';
  if (type === 'sell') return 'sell';
  if (type === 'dividend') return 'dividend';
  return 'fee';
};

const getAssetName = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset ? asset.name : 'Desconocido';
};

const getAssetTicker = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset?.ticker || '';
};

const getAssetCurrency = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset?.currency || 'EUR';
};

const getShortName = (name: string) => {
  const parts = name.split(' ');
  return parts.length > 1 && name.length > 18 ? parts[0] : name;
};

const getQuantityDecimals = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset?.type === 'crypto' ? 8 : 4;
};

const formatQuantity = (value: number, assetId: string) => {
  return value.toLocaleString('es-ES', {
    minimumFractionDigits: 2,
    maximumFractionDigits: getQuantityDecimals(assetId),
  });
};

const formatMoney = (value: number, currency: string) => {
  return formatCurrency(value, currency);
};
---

<div class="transactions-container">
  <table class="transactions-table">
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Tipo</th>
        <th>Activo</th>
        <th>Cantidad</th>
        <th>Precio Unitario</th>
        <th>Comisión</th>
        <th>Total</th>
        <th>P&L realizado</th>
        {showDelete && <th style="width: 64px;">Acciones</th>}
      </tr>
    </thead>
    <tbody>
      {displayTransactions.map((tx) => {
        const currency = getAssetCurrency(tx.asset_id);
        const assetName = getAssetName(tx.asset_id);
        const ticker = getAssetTicker(tx.asset_id);
        const total = tx.quantity * tx.unit_price + (tx.fee || 0);
        const averageCost = averageCostByAsset.get(tx.asset_id) || 0;
        const realizedPnL =
          tx.type === 'sell' ? (tx.unit_price - averageCost) * tx.quantity : null;
        return (
          <tr data-tradingview-open data-asset-name={assetName} data-ticker={ticker} class="transaction-row">
            <td>
              {new Date(tx.date).toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </td>
            <td>
              <span class:list={['transaction-type', getTypeClass(tx.type)]}>
                {typeLabels[tx.type]}
              </span>
            </td>
            <td>
              <div class="asset-name">
                <span title={assetName}>{getShortName(assetName)}</span>
                <span class="asset-ticker">{getAssetTicker(tx.asset_id)}</span>
              </div>
            </td>
            <td>{formatQuantity(tx.quantity, tx.asset_id)}</td>
            <td>{formatMoney(tx.unit_price, currency)}</td>
            <td>
              {tx.fee && tx.fee !== 0 ? formatMoney(tx.fee, currency) : <span class="muted-cell">-</span>}
            </td>
            <td class="total-cell">{formatMoney(total, currency)}</td>
            <td
              class:list={[
                realizedPnL === null
                  ? 'muted-cell'
                  : realizedPnL >= 0
                    ? 'pnl-positive'
                    : 'pnl-negative',
              ]}
            >
              {realizedPnL === null ? '-' : formatMoney(realizedPnL, currency)}
            </td>
            {showDelete && (
              <td class="actions-cell">
                <button
                  class="edit-btn"
                  data-edit-transaction={tx.id}
                  data-type={tx.type}
                  data-quantity={tx.quantity}
                  data-price={tx.unit_price}
                  data-date={tx.date}
                  data-fee={tx.fee}
                  data-notes={tx.notes}
                  title="Editar transacción"
                >
                  ✏️
                </button>
                <button
                  class="delete-btn"
                  data-transaction-id={tx.id}
                  title="Eliminar transacción"
                >
                  ✕
                </button>
              </td>
            )}
          </tr>
        );
      })}
    </tbody>
  </table>
  {displayTransactions.length === 0 && (
    <div class="empty-table">
      No hay transacciones
    </div>
  )}
</div>

<style>
  .transactions-container {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-2xl);
    overflow: auto;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .transactions-table {
    width: 100%;
    border-collapse: collapse;
  }

  .transactions-table thead {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border-bottom: 1px solid var(--pf-border);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .transactions-table th {
    padding: 0.55rem 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.72rem;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .transactions-table td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--pf-border);
    color: var(--pf-text);
    vertical-align: middle;
  }

  .transactions-table tbody tr {
    background: transparent;
    border-bottom: 1px solid #2a2d3a;
  }

  .transaction-row {
    cursor: pointer;
  }

  .transaction-type {
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .transaction-type.buy {
    background: rgba(34, 197, 94, 0.08);
    color: #15803d;
  }

  .transaction-type.sell {
    background: rgba(239, 68, 68, 0.08);
    color: #b91c1c;
  }

  .transaction-type.dividend {
    background: rgba(37, 99, 235, 0.08);
    color: #1d4ed8;
  }

  .transaction-type.fee {
    background: rgba(148, 163, 184, 0.12);
    color: #475569;
  }

  .asset-name {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }

  .asset-name > span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 180px;
    display: inline-block;
  }

  .asset-ticker {
    font-size: 0.8rem;
    color: var(--pf-text-muted);
    font-weight: 500;
    background: #eef2ff;
    border-radius: var(--radius-md);
    padding: 0.2rem 0.45rem;
    line-height: 1;
  }

  .total-cell {
    font-weight: 700;
  }

  .muted-cell {
    color: #64748b;
  }

  .actions-cell {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .edit-btn {
    background: #f8fafc;
    border: 1px solid var(--pf-border);
    color: #475569;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .edit-btn:hover {
    background: #eef2ff;
    color: #1d4ed8;
  }

  .delete-btn {
    background: #fff1f2;
    border: 1px solid #fecdd3;
    color: #b91c1c;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .delete-btn:hover {
    background: #ffe4e6;
    color: #991b1b;
  }

  .empty-table {
    padding: 1.25rem;
    text-align: center;
    color: var(--pf-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .transactions-table {
      font-size: 0.875rem;
    }

    .transactions-table th,
    .transactions-table td {
      padding: 0.55rem 0.75rem;
    }

  }
</style>
<script>
  function initTransactionButtons() {
    const editButtons = document.querySelectorAll('[data-edit-transaction]');
    const deleteButtons = document.querySelectorAll('[data-transaction-id]');
    const actionButtons = document.querySelectorAll('.edit-btn, .delete-btn');

    actionButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => e.stopPropagation());
    });

    editButtons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();

        const txId = btn.getAttribute('data-edit-transaction');
        const type = btn.getAttribute('data-type');
        const quantity = btn.getAttribute('data-quantity');
        const price = btn.getAttribute('data-price');
        const date = btn.getAttribute('data-date');
        const fee = btn.getAttribute('data-fee');
        const notes = btn.getAttribute('data-notes');

        if (window.openEditTransactionModal) {
          window.openEditTransactionModal(txId, type, quantity, price, date, fee, notes);
        }
      });
    });

    deleteButtons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();

        if (!confirm('¿Eliminar esta transacción?')) {
          return;
        }

        const transactionId = btn.getAttribute('data-transaction-id');

        try {
          const response = await fetch('/api/transaction/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: transactionId }),
          });

          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Error desconocido');
          }

          window.location.reload();
        } catch (error) {
          alert(`Error: ${error instanceof Error ? error.message : 'Error al eliminar'}`);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionButtons);
  } else {
    initTransactionButtons();
  }
</script>
