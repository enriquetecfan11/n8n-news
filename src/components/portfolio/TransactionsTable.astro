---
import type { Transaction, Asset } from '../../lib/portfolio';
import { formatCurrency } from '../../lib/portfolio';

interface Props {
  transactions: Transaction[];
  assets: Map<string, Asset>;
  limit?: number;
  showDelete?: boolean;
}

const { transactions, assets, limit, showDelete = false } = Astro.props;
const displayTransactions = limit ? transactions.slice(0, limit) : transactions;

const typeLabels: Record<string, string> = {
  buy: 'Compra',
  sell: 'Venta',
  dividend: 'Dividendo',
  fee: 'Comisión',
};

const getTypeClass = (type: string) => {
  if (type === 'buy') return 'buy';
  if (type === 'sell') return 'sell';
  if (type === 'dividend') return 'dividend';
  return 'fee';
};

const getAssetName = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset ? asset.name : 'Desconocido';
};

const getAssetTicker = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset?.ticker || '';
};

const getAssetCurrency = (assetId: string) => {
  const asset = assets.get(assetId);
  return asset?.currency || 'EUR';
};
---

<div class="transactions-container">
  <table class="transactions-table">
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Tipo</th>
        <th>Activo</th>
        <th>Cantidad</th>
        <th>Precio Unitario</th>
        <th>Comisión</th>
        <th>Total</th>
        <th>Notas</th>
        {showDelete && <th style="width: 50px;">Acciones</th>}
      </tr>
    </thead>
    <tbody>
      {displayTransactions.map((tx) => {
        const currency = getAssetCurrency(tx.asset_id);
        const total = tx.quantity * tx.unit_price + (tx.fee || 0);
        return (
          <tr>
            <td>
              {new Date(tx.date).toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </td>
            <td>
              <span class:list={['transaction-type', getTypeClass(tx.type)]}>
                {typeLabels[tx.type]}
              </span>
            </td>
            <td>
              <div class="asset-name">
                <span>{getAssetName(tx.asset_id)}</span>
                <span class="asset-ticker">{getAssetTicker(tx.asset_id)}</span>
              </div>
            </td>
            <td>{tx.quantity.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 8 })}</td>
            <td>{formatCurrency(tx.unit_price, currency)}</td>
            <td>{formatCurrency(tx.fee || 0, currency)}</td>
            <td class="total-cell">{formatCurrency(total, currency)}</td>
            <td style="font-size: 0.875rem; color: #94a3b8;">{tx.notes || '-'}</td>
            {showDelete && (
              <td class="actions-cell">
                <button
                  class="edit-btn"
                  data-edit-transaction={tx.id}
                  data-type={tx.type}
                  data-quantity={tx.quantity}
                  data-price={tx.unit_price}
                  data-date={tx.date}
                  data-fee={tx.fee}
                  data-notes={tx.notes}
                  title="Editar transacción"
                >
                  ✎
                </button>
                <button
                  class="delete-btn"
                  data-transaction-id={tx.id}
                  title="Eliminar transacción"
                >
                  ✕
                </button>
              </td>
            )}
          </tr>
        );
      })}
    </tbody>
  </table>
  {displayTransactions.length === 0 && (
    <div style="padding: 2rem; text-align: center; color: #94a3b8;">
      No hay transacciones
    </div>
  )}
</div>

<style>
  .transactions-container {
    background: #1a1d27;
    border: 1px solid #2a2d3a;
    border-radius: var(--radius-xl);
    overflow: auto;
  }

  .transactions-table {
    width: 100%;
    border-collapse: collapse;
  }

  .transactions-table thead {
    background: #0f1117;
    border-bottom: 1px solid #2a2d3a;
  }

  .transactions-table th {
    padding: 1rem var(--space-md);
    text-align: left;
    font-weight: 700;
    font-size: 0.75rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.75px;
  }

  .transactions-table td {
    padding: 1rem var(--space-md);
    border-bottom: 1px solid #2a2d3a;
    color: #f8fafc;
  }

  .transactions-table tbody tr {
    background: #1a1d27;
    transition: background-color 0.2s ease;
  }

  .transactions-table tbody tr:nth-child(even) {
    background: #1e2130;
  }

  .transactions-table tbody tr:hover {
    background: #232738;
  }

  .transaction-type {
    font-weight: 700;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .transaction-type.buy {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .transaction-type.sell {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .transaction-type.dividend {
    background: rgba(99, 102, 241, 0.15);
    color: #6366f1;
  }

  .transaction-type.fee {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .asset-name {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .asset-ticker {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 500;
  }

  .total-cell {
    font-weight: 700;
  }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .edit-btn {
    background: none;
    border: none;
    color: #6366f1;
    cursor: pointer;
    font-size: 1.25rem;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .edit-btn:hover {
    background: rgba(99, 102, 241, 0.15);
    color: #818cf8;
  }

  .delete-btn {
    background: none;
    border: none;
    color: #ef4444;
    cursor: pointer;
    font-size: 1.25rem;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .delete-btn:hover {
    background: rgba(239, 68, 68, 0.15);
    color: #fca5a5;
  }

  @media (max-width: 768px) {
    .transactions-table {
      font-size: 0.875rem;
    }

    .transactions-table th,
    .transactions-table td {
      padding: var(--space-sm);
    }
  }
</style>

<script>
  function initTransactionButtons() {
    const editButtons = document.querySelectorAll('[data-edit-transaction]');
    const deleteButtons = document.querySelectorAll('[data-transaction-id]');

    editButtons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();

        const txId = btn.getAttribute('data-edit-transaction');
        const type = btn.getAttribute('data-type');
        const quantity = btn.getAttribute('data-quantity');
        const price = btn.getAttribute('data-price');
        const date = btn.getAttribute('data-date');
        const fee = btn.getAttribute('data-fee');
        const notes = btn.getAttribute('data-notes');

        if (window.openEditTransactionModal) {
          window.openEditTransactionModal(txId, type, quantity, price, date, fee, notes);
        }
      });
    });

    deleteButtons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();

        if (!confirm('¿Eliminar esta transacción?')) {
          return;
        }

        const transactionId = btn.getAttribute('data-transaction-id');

        try {
          const response = await fetch('/api/transaction/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: transactionId }),
          });

          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Error desconocido');
          }

          window.location.reload();
        } catch (error) {
          alert(`Error: ${error instanceof Error ? error.message : 'Error al eliminar'}`);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionButtons);
  } else {
    initTransactionButtons();
  }
</script>
