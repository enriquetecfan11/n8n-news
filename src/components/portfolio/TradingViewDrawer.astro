---
interface Props {
  id?: string;
}

const { id = 'tradingview-drawer' } = Astro.props;
---

<aside id={id} class="tradingview-drawer hidden" aria-hidden="true">
  <div class="tradingview-drawer-header">
    <div>
      <p class="tradingview-drawer-kicker">TradingView</p>
      <h2 id="tradingview-title" class="tradingview-drawer-title">Gráfico</h2>
      <p id="tradingview-ticker" class="tradingview-drawer-subtitle"></p>
    </div>
    <button type="button" class="tradingview-drawer-close" data-tradingview-close aria-label="Cerrar">
      ✕
    </button>
  </div>

  <div class="tradingview-drawer-body">
    <div class="tradingview-widget-shell">
      <div id="tradingview-widget-root" class="tradingview-widget-container h-full">
        <div id="tradingview_chart"></div>
      </div>
    </div>
  </div>
</aside>

<script src="https://s3.tradingview.com/tv.js"></script>
<script is:inline>
  (() => {
    const drawer = document.getElementById('tradingview-drawer');
    const title = document.getElementById('tradingview-title');
    const tickerLabel = document.getElementById('tradingview-ticker');
    const widgetRoot = document.getElementById('tradingview-widget-root');
    const chartEl = document.getElementById('tradingview_chart');

    if (!drawer || !title || !tickerLabel || !widgetRoot || !chartEl) return;

    const closeDrawer = () => {
      drawer.classList.add('hidden');
      drawer.setAttribute('aria-hidden', 'true');
      chartEl.innerHTML = '';
    };

    const openDrawer = (assetName, ticker) => {
      title.textContent = assetName || 'Gráfico';
      tickerLabel.textContent = ticker || '';
      drawer.classList.remove('hidden');
      drawer.setAttribute('aria-hidden', 'false');
      chartEl.innerHTML = '';

      if (window.TradingView) {
        new window.TradingView.widget({
          container_id: 'tradingview_chart',
          symbol: ticker,
          interval: 'D',
          theme: 'dark',
          style: '1',
          locale: 'es',
          toolbar_bg: '#0f1117',
          backgroundColor: 'rgba(0,0,0,0)',
          enable_publishing: false,
          hide_side_toolbar: false,
          allow_symbol_change: true,
          height: '100%',
          width: '100%',
        });
      }
    };

    document.addEventListener('click', (event) => {
      const trigger = event.target instanceof Element ? event.target.closest('[data-tradingview-open]') : null;
      const closeBtn = event.target instanceof Element ? event.target.closest('[data-tradingview-close]') : null;

      if (closeBtn) {
        closeDrawer();
        return;
      }

      if (!trigger) return;

      const assetName = trigger.getAttribute('data-asset-name') || '';
      const ticker = trigger.getAttribute('data-ticker') || '';
      if (!ticker) return;
      openDrawer(assetName, ticker);
    });
  })();
</script>

<style>
  .tradingview-drawer {
    position: fixed;
    right: 0;
    top: 0;
    height: 100vh;
    width: min(40vw, 680px);
    z-index: 40;
    background: #1e2433;
    border-left: 1px solid #2a2d3a;
    display: flex;
    flex-direction: column;
  }

  .tradingview-drawer.hidden {
    display: none;
  }

  .tradingview-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid #2a2d3a;
    color: #f8fafc;
  }

  .tradingview-drawer-kicker,
  .tradingview-drawer-subtitle {
    margin: 0;
    color: #94a3b8;
  }

  .tradingview-drawer-title {
    margin: 0.15rem 0;
    color: #f8fafc;
    font-size: 1rem;
  }

  .tradingview-drawer-close {
    background: transparent;
    border: 1px solid #2a2d3a;
    color: #f8fafc;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    cursor: pointer;
  }

  .tradingview-drawer-body {
    flex: 1;
    min-height: 0;
  }

  .tradingview-widget-shell {
    background: #0f1117;
    border-radius: 12px;
    overflow: hidden;
    height: 100%;
  }

  #tradingview_chart {
    width: 100%;
    height: 100%;
    min-height: calc(100vh - 72px);
  }
</style>
