---
interface Props {
  label: string;
  value: string | number;
  change?: number;
  context?: string;
  color?: 'default' | 'positive' | 'negative';
  compact?: boolean;
}

const { label, value, change, context = '', color = 'default', compact = false } = Astro.props;

const changeClass =
  change !== undefined ? (change >= 0 ? 'positive' : 'negative') : null;
---

<div class:list={['kpi-card', compact && 'kpi-card-compact']}>
  <span class="kpi-label">{label}</span>
  <span class="kpi-value">{value}</span>
  {context && <span class="kpi-context">{context}</span>}
  {change !== undefined && (
    <span class:list={['kpi-change', changeClass]}>
      {change >= 0 ? '+' : ''}{change.toFixed(2)}%
    </span>
  )}
</div>

<style>
  .kpi-card {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-2xl);
    padding: 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .kpi-card:hover {
    background: var(--pf-card-hover);
  }

  .kpi-card-compact {
    padding: 0.85rem 0.95rem;
    gap: 0.2rem;
  }

  .kpi-label {
    font-size: 0.75rem;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .kpi-value {
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    font-weight: 700;
    color: var(--pf-text);
    line-height: 1;
    font-family: var(--font-family-mono);
    letter-spacing: -0.03em;
  }

  .kpi-change {
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    border-radius: var(--radius-md);
    width: fit-content;
    font-family: var(--font-family-mono);
    font-weight: 600;
  }

  .kpi-suffix {
    font-size: 0.56em;
    margin-left: 0.25rem;
    color: var(--pf-text-muted);
  }

  .kpi-context {
    color: #64748b;
    font-size: 0.85rem;
    line-height: 1.1;
  }

  .kpi-card-compact .kpi-label {
    font-size: 0.68rem;
  }

  .kpi-card-compact .kpi-value {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
  }

  .kpi-card-compact .kpi-context {
    font-size: 0.78rem;
  }

  .kpi-change.positive {
    background: rgba(34, 197, 94, 0.08);
    color: #15803d;
  }

  .kpi-change.negative {
    background: rgba(239, 68, 68, 0.08);
    color: #b91c1c;
  }
</style>
