---
interface Props {
  label: string;
  value: string | number;
  change?: number;
  suffix?: string;
  color?: 'default' | 'positive' | 'negative';
}

const { label, value, change, suffix = '', color = 'default' } = Astro.props;

const changeClass =
  change !== undefined ? (change >= 0 ? 'positive' : 'negative') : null;
---

<div class="kpi-card">
  <span class="kpi-label">{label}</span>
  <span class="kpi-value">
    {value}{suffix && <span style="font-size: 0.6em; margin-left: 0.25em;">{suffix}</span>}
  </span>
  {change !== undefined && (
    <span class:list={['kpi-change', changeClass]}>
      {change >= 0 ? '+' : ''}{change.toFixed(2)}%
    </span>
  )}
</div>

<style>
  .kpi-card {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .kpi-card:hover {
    border-color: #6366f1;
    background: var(--pf-card-hover);
  }

  .kpi-label {
    font-size: 0.75rem;
    color: var(--pf-text-muted);
    margin-bottom: var(--space-md);
    text-transform: uppercase;
    letter-spacing: 0.75px;
    font-weight: 600;
  }

  .kpi-value {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--pf-text);
    line-height: 1.1;
    font-family: var(--font-family-mono);
    letter-spacing: -0.02em;
  }

  .kpi-change {
    font-size: 0.875rem;
    margin-top: var(--space-md);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    width: fit-content;
    font-family: var(--font-family-mono);
    font-weight: 600;
  }

  .kpi-change.positive {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
  }

  .kpi-change.negative {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }
</style>
