---
import Modal from '../Modal.astro';

interface Props {
  portfolioId: string;
  assets?: Array<{ id: string; name: string; ticker: string }>;
}

const { portfolioId, assets = [] } = Astro.props;
---

<Modal id="modal-registrar-transaccion" title="Registrar Transacción">
  <form id="transaction-form" class="space-y-4">
    <input type="hidden" name="portfolioId" value={portfolioId} />

    <div id="sell-position-banner" class="hidden sell-position-banner">
      <span class="sell-position-label">Venta desde posición</span>
      <span id="sell-position-summary" class="sell-position-summary"></span>
    </div>

    <div>
      <label for="transaction-asset" class="block text-sm font-medium text-slate-300 mb-1.5">
        Activo <span class="text-red-500">*</span>
      </label>
      <select
        id="transaction-asset"
        name="assetId"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        required
      >
        <option value="">Selecciona un activo...</option>
        {assets.map((asset) => (
          <option value={asset.id}>
            {asset.name} ({asset.ticker})
          </option>
        ))}
      </select>
    </div>

    <div>
      <label for="transaction-type" class="block text-sm font-medium text-slate-300 mb-1.5">
        Tipo <span class="text-red-500">*</span>
      </label>
      <select
        id="transaction-type"
        name="type"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        required
      >
        <option value="buy">Compra</option>
        <option value="sell">Venta</option>
        <option value="dividend">Dividendo</option>
        <option value="fee">Comisión</option>
      </select>
    </div>

    <div>
      <label for="transaction-quantity" class="block text-sm font-medium text-slate-300 mb-1.5">
        Cantidad <span class="text-red-500">*</span>
      </label>
      <input
        id="transaction-quantity"
        type="number"
        name="quantity"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="10.5"
        step="0.00000001"
        required
      />
    </div>

    <div>
      <label for="transaction-price" class="block text-sm font-medium text-slate-300 mb-1.5">
        Precio Unitario <span class="text-red-500">*</span>
      </label>
      <input
        id="transaction-price"
        type="number"
        name="unitPrice"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="150.50"
        step="0.01"
        required
      />
    </div>

    <div>
      <label for="transaction-fee" class="block text-sm font-medium text-slate-300 mb-1.5">
        Comisión
      </label>
      <input
        id="transaction-fee"
        type="number"
        name="fee"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="0.00"
        step="0.01"
        value="0"
      />
      <span class="text-xs text-[#6b7a99] mt-1">Opcional</span>
    </div>

    <div>
      <label for="transaction-date" class="block text-sm font-medium text-slate-300 mb-1.5">
        Fecha <span class="text-red-500">*</span>
      </label>
      <input
        id="transaction-date"
        type="date"
        name="date"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500"
        required
        value={new Date().toISOString().split('T')[0]}
      />
    </div>

    <div>
      <label for="transaction-notes" class="block text-sm font-medium text-slate-300 mb-1.5">
        Notas
      </label>
      <textarea
        id="transaction-notes"
        name="notes"
        class="w-full bg-[#2a3347] text-white placeholder:text-[#6b7a99] rounded-xl px-4 py-3 text-sm border-0 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
        placeholder="Detalles adicionales..."
        rows="2"
      ></textarea>
      <span class="text-xs text-[#6b7a99] mt-1">Opcional</span>
    </div>

    <button
      type="submit"
      class="w-full mt-6 bg-blue-500 hover:bg-blue-400 text-white font-semibold rounded-xl px-6 py-3 transition-colors"
    >
      Registrar Transacción
    </button>
  </form>

  <div id="transaction-status" class="hidden mt-4 p-3 rounded-lg text-sm font-medium"></div>
</Modal>

<script>
  function initTransactionModal() {
    const modal = document.getElementById('modal-registrar-transaccion');
    const form = document.getElementById('transaction-form');
    const statusDiv = document.getElementById('transaction-status');
    const banner = document.getElementById('sell-position-banner');
    const bannerSummary = document.getElementById('sell-position-summary');
    const modalTitle = modal?.querySelector('.modal-title');
    const submitBtn = form.querySelector('button[type="submit"]');

    if (!modal || !form) return;

    const today = () => new Date().toISOString().split('T')[0];

    const resetBanner = () => {
      if (!banner) return;
      banner.classList.add('hidden');
      if (bannerSummary) bannerSummary.textContent = '';
    };

    window.openAddTransactionModal = (prefill) => {
      const assetSelect = document.getElementById('transaction-asset') as HTMLSelectElement | null;
      const typeSelect = document.getElementById('transaction-type') as HTMLSelectElement | null;
      const quantityInput = document.getElementById('transaction-quantity') as HTMLInputElement | null;
      const priceInput = document.getElementById('transaction-price') as HTMLInputElement | null;
      const feeInput = document.getElementById('transaction-fee') as HTMLInputElement | null;
      const dateInput = document.getElementById('transaction-date') as HTMLInputElement | null;
      const notesInput = document.getElementById('transaction-notes') as HTMLTextAreaElement | null;

      if (assetSelect) assetSelect.value = prefill?.assetId || '';
      if (typeSelect) typeSelect.value = prefill?.type || 'buy';
      if (quantityInput) quantityInput.value = prefill?.quantity || '';
      if (priceInput) priceInput.value = prefill?.unitPrice || '';
      if (feeInput) feeInput.value = prefill?.fee || '0';
      if (dateInput) dateInput.value = prefill?.date || today();
      if (notesInput) notesInput.value = prefill?.notes || '';

      if (modalTitle) {
        modalTitle.textContent = prefill?.title || 'Registrar Transacción';
      }

      if (submitBtn) {
        submitBtn.textContent =
          prefill?.type === 'sell' ? 'Registrar venta' : prefill?.duplicate ? 'Duplicar orden' : 'Registrar Transacción';
      }

      if (banner && bannerSummary && prefill?.positionSummary) {
        bannerSummary.textContent = prefill.positionSummary;
        banner.classList.remove('hidden');
      } else {
        resetBanner();
      }

      if (statusDiv) {
        statusDiv.textContent = '';
        statusDiv.className = 'hidden';
      }
      modal.classList.remove('hidden');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {
        portfolioId: formData.get('portfolioId'),
        assetId: formData.get('assetId'),
        type: formData.get('type'),
        quantity: formData.get('quantity'),
        unitPrice: formData.get('unitPrice'),
        date: formData.get('date'),
        fee: formData.get('fee'),
        notes: formData.get('notes'),
      };

      try {
        statusDiv.textContent = 'Registrando...';
        statusDiv.className = '';

        const response = await fetch('/api/transaction/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Error desconocido');
        }

        statusDiv.textContent = '✓ Transacción registrada. Recargando...';
        statusDiv.className = 'show-success';

        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } catch (error) {
        statusDiv.textContent = `✗ ${error instanceof Error ? error.message : 'Error'}`;
        statusDiv.className = 'show-error';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionModal);
  } else {
    initTransactionModal();
  }
</script>

<style>
  .sell-position-banner {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sell-position-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f87171;
  }

  .sell-position-summary {
    font-size: 0.875rem;
    color: var(--pf-text, #e2e8f0);
    line-height: 1.45;
  }

  #transaction-status.show-error {
    display: block !important;
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  #transaction-status.show-success {
    display: block !important;
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
</style>
