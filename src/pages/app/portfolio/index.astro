---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortfolioCard from '../../../components/portfolio/PortfolioCard.astro';
import CreatePortfolioModal from '../../../components/portfolio/CreatePortfolioModal.astro';
import { getHoldings, getPortfolioSummary } from '../../../lib/portfolio';
import { getAssetsByPortfolio, getPortfoliosByUser, getTransactionsByPortfolio } from '../../../lib/supabase';

const user = Astro.locals.user as { id: string };
if (!user?.id) {
  return Astro.redirect('/login');
}
const portfolios = await getPortfoliosByUser(user.id);
const enriched = await Promise.all(
  portfolios.map(async (portfolio) => {
    const transactions = await getTransactionsByPortfolio(portfolio.id);
    const assets = await getAssetsByPortfolio(portfolio.id);
    const holdings = getHoldings(transactions, new Map(assets.map((asset) => [asset.id, asset])));
    const summary = getPortfolioSummary(holdings);
    return { ...portfolio, ...summary };
  })
);
---

<BaseLayout title="Portfolio">
  <main class="page">
    <section class="top">
      <div>
        <p class="eyebrow">Portfolio</p>
        <h1>Gestiona tus portfolios</h1>
      </div>
      <button class="cta" onclick="document.getElementById('modal-nuevo-portfolio').classList.remove('hidden')">Crear portfolio</button>
    </section>

    <section class="cards">
      {enriched.map((portfolio) => (
        <PortfolioCard portfolio={portfolio} totalValue={portfolio.totalValue} totalCost={portfolio.totalCost} pnlAbsolute={portfolio.pnlAbsolute} pnlPercent={portfolio.pnlPercent} />
      ))}
    </section>
  </main>
  <CreatePortfolioModal />
</BaseLayout>

<style>
  .page{max-width:1440px;margin:0 auto;padding:2.5rem 1.75rem 4.5rem}
  .top{display:flex;justify-content:space-between;gap:1.25rem;align-items:end;margin-bottom:1.75rem}
  h1{color:#f8fafc;font-size:clamp(2rem,3vw,2.8rem);line-height:1.05}
  .eyebrow{color:#94a3b8;font-size:0.8rem;text-transform:uppercase;letter-spacing:.12em}
  .cta{border:0;border-radius:1rem;padding:1rem 1.25rem;background:linear-gradient(135deg,#2563eb,#0ea5e9);color:white;font-weight:700;font-size:0.95rem}
  .cards{display:grid;gap:1.25rem}
</style>
