---
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ThemeInit from "../components/ThemeInit.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import TradingDashboard from "../components/finance/TradingDashboard.jsx";
import { getCollection } from 'astro:content';
import "../styles/global.css";
import "../styles/design-tokens.css";
import "../styles/motion.css";
import "../styles/animations.css";
import "../styles/theme.css";
import "../styles/trading-dashboard.css";

const news = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    title: post.data.title,
    url: `/blog/${post.slug}`,
    source: post.data.source || 'Noticias',
    date: post.data.pubDate.toLocaleDateString('es-ES'),
  }));
---

<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <BaseHead title={`Mercados en tiempo real | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Navbar />
    <main class="main-content">
      <TradingDashboard client:load news={news} />
    </main>
    <Footer />
  </body>
</html>
