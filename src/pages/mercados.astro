---
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ThemeInit from "../components/ThemeInit.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import TradingDashboard from "../components/finance/TradingDashboard.jsx";
import { getCollection } from 'astro:content';
import "../styles/global.css";
import "../styles/design-tokens.css";
import "../styles/motion.css";
import "../styles/animations.css";
import "../styles/theme.css";

const news = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    title: post.data.title,
    url: `/blog/${post.slug}`,
    source: post.data.source || 'Noticias',
    date: post.data.pubDate.toLocaleDateString('es-ES'),
  }));
---

<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <BaseHead title={`Mercados en tiempo real | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Navbar />
    <main class="main-content">
      <TradingDashboard client:load news={news} />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  .market-shell {
    width: 100%;
    max-width: 1720px;
    margin: 0 auto;
    padding: 0 1rem 1.5rem;
    color: inherit;
  }

  .market-tape {
    width: 100%;
    border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    margin-bottom: 1rem;
  }

  .widget-slot-tape {
    min-height: 44px;
  }

  .market-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .market-hero__copy h1 {
    margin: 0.2rem 0 0.4rem;
    font-size: clamp(1.65rem, 3vw, 2.6rem);
    line-height: 1.05;
  }

  .eyebrow,
  .card-kicker,
  .section-caption,
  .info-card__title {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 700;
    color: color-mix(in srgb, currentColor 55%, transparent);
  }

  .hero-text {
    max-width: 62ch;
    margin: 0;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .market-symbols {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .symbol-pill,
  .market-tab,
  .asset-row {
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
    color: inherit;
    border-radius: 999px;
    cursor: pointer;
    transition: transform 0.18s ease, background-color 0.18s ease, border-color 0.18s ease;
  }

  .symbol-pill {
    padding: 0.55rem 0.85rem;
    font-weight: 600;
  }

  .symbol-pill.is-active,
  .market-tab.is-active,
  .asset-row.is-active {
    border-color: color-mix(in srgb, var(--accent, #3b82f6) 55%, transparent);
    background: color-mix(in srgb, var(--accent, #3b82f6) 12%, transparent);
  }

  .main-chart-card,
  .panel,
  .info-card {
    border: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    background: color-mix(in srgb, currentColor 2%, transparent);
    backdrop-filter: blur(10px);
    border-radius: 18px;
  }

  .main-chart-card {
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .chart-card__header,
  .panel-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 0;
  }

  .chart-card__header h2,
  .panel-heading h3 {
    margin: 0.15rem 0 0;
  }

  .chart-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: color-mix(in srgb, currentColor 72%, transparent);
    font-size: 0.92rem;
  }

  .status-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: #22c55e;
    box-shadow: 0 0 0 4px color-mix(in srgb, #22c55e 18%, transparent);
  }

  .chart-card__body {
    padding: 0.85rem;
  }

  .market-tabs {
    display: flex;
    gap: 0.65rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin-bottom: 0.9rem;
  }

  .market-tab {
    padding: 0.8rem 1rem;
    white-space: nowrap;
    border-radius: 999px;
    font-weight: 600;
  }

  .tab-stage {
    min-height: 200px;
  }

  .chart-tab-grid,
  .market-grid {
    display: grid;
    gap: 1rem;
  }

  .chart-tab-grid {
    grid-template-columns: 320px minmax(0, 1fr);
  }

  .info-stack {
    display: grid;
    gap: 1rem;
  }

  .info-card {
    padding: 1rem;
  }

  .mini-stat,
  .market-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
  }

  .mini-stat:last-child,
  .market-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .mini-stat span,
  .market-row span,
  .news-source,
  .news-date {
    color: color-mix(in srgb, currentColor 68%, transparent);
    font-size: 0.92rem;
  }

  .focus-panel {
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    padding: 1rem;
  }

  .focus-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .metric-card {
    padding: 1rem;
    border-radius: 16px;
    background: color-mix(in srgb, currentColor 4%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 8%, transparent);
  }

  .metric-card span,
  .metric-card strong,
  .info-card strong {
    display: block;
  }

  .panel {
    padding-bottom: 1rem;
  }

  .panel-wide {
    overflow: hidden;
  }

  .widget-slot-heatmap {
    min-height: 720px;
    padding: 0.5rem 1rem 1rem;
  }

  .widget-slot-overview {
    min-height: 660px;
    padding: 0.5rem 1rem 1rem;
  }

  .market-grid {
    grid-template-columns: 1.2fr 0.8fr 0.8fr;
  }

  .panel-list,
  .panel-news {
    padding: 1rem;
  }

  .panel-list h3,
  .panel-news h3 {
    margin: 0 0 0.85rem;
  }

  .sector-row {
    align-items: start;
  }

  .news-list-modern {
    display: grid;
    gap: 0.8rem;
    padding: 0 1rem 1rem;
  }

  .news-item {
    display: block;
    padding: 1rem;
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    border: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    background: color-mix(in srgb, currentColor 3%, transparent);
  }

  .news-item:hover,
  .symbol-pill:hover,
  .market-tab:hover,
  .asset-row:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent, #3b82f6) 35%, transparent);
  }

  .news-item__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }

  .news-item h4 {
    margin: 0;
    line-height: 1.35;
  }

  .positive { color: #22c55e; }
  .negative { color: #ef4444; }

  .widget-slot,
  .widget-slot > script,
  .widget-slot iframe {
    width: 100%;
  }

  .widget-slot-heatmap iframe,
  .widget-slot-overview iframe {
    min-height: inherit;
  }

  @media (max-width: 1100px) {
    .market-hero {
      align-items: start;
      flex-direction: column;
    }

    .chart-tab-grid,
    .market-grid {
      grid-template-columns: 1fr;
    }

    .focus-metrics {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .market-shell {
      padding-inline: 0.75rem;
    }

    .chart-card__header,
    .panel-heading,
    .news-item__top {
      flex-direction: column;
      align-items: start;
    }

    .widget-slot-heatmap,
    .widget-slot-overview {
      min-height: 540px;
    }
  }
</style>
