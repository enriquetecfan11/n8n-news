---
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ThemeInit from "../components/ThemeInit.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import TradingDashboard from "../components/finance/TradingDashboard.jsx";
import { getCollection } from 'astro:content';
import "../styles/global.css";
import "../styles/design-tokens.css";
import "../styles/motion.css";
import "../styles/animations.css";
import "../styles/theme.css";

const news = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    title: post.data.title,
    url: `/blog/${post.slug}`,
    source: post.data.source || 'Noticias',
    date: post.data.pubDate.toLocaleDateString('es-ES'),
  }));
---

<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <BaseHead title={`Mercados en tiempo real | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Navbar />
    <main class="main-content">
      <TradingDashboard client:load news={news} />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html, body {
    background: #0b0d12;
    color: #e5e7eb;
  }

  .main-content {
    background: #0b0d12;
  }

  .market-shell {
    width: 100%;
    max-width: 1720px;
    margin: 0 auto;
    padding: 0 1rem 1.25rem;
    color: #e5e7eb;
  }

  .market-tape {
    width: 100%;
    background: #0b0d12;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 1rem;
  }

  .widget-slot-tape {
    min-height: 44px;
    background: #0b0d12;
    overflow: hidden;
  }

  .market-tab,
  .panel {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #11141b;
    backdrop-filter: blur(10px);
    border-radius: 16px;
  }

  .panel-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 0;
  }

  .panel-heading h3 {
    margin: 0.15rem 0 0;
  }

  .market-tabs {
    display: flex;
    align-items: end;
    overflow-x: auto;
    gap: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    margin-bottom: 1rem;
  }

  .market-tab {
    position: relative;
    padding: 0.85rem 1rem 0.95rem;
    white-space: nowrap;
    border-radius: 0;
    border: 0;
    border-bottom: 2px solid transparent;
    background: transparent;
    font-weight: 600;
    color: rgba(229, 231, 235, 0.68);
  }

  .market-tab.is-active {
    color: inherit;
    border-bottom-color: var(--accent, #3b82f6);
    background: transparent;
  }

  .market-tab span {
    display: inline-block;
    padding-bottom: 0.05rem;
  }

  .tab-stage {
    min-height: 0;
  }

  .full-bleed-panel,
  .panel {
    padding-bottom: 1rem;
  }

  .full-bleed-panel {
    width: 100%;
    min-height: calc(100vh - 170px);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #11141b;
    border-radius: 16px;
  }

  .panel-wide {
    overflow: hidden;
  }

  .full-bleed-panel .tradingview-shell--chart,
  .full-bleed-panel .tradingview-widget-container {
    width: 100%;
    height: calc(100vh - 220px);
    min-height: 900px;
  }

  .full-bleed-panel .tradingview-widget-container__widget,
  .full-bleed-panel iframe {
    width: 100%;
    height: 100%;
    min-height: 900px;
  }

  .widget-slot-heatmap {
    min-height: calc(100vh - 170px);
    padding: 0;
  }

  .widget-slot-overview {
    min-height: calc(100vh - 320px);
    padding: 0;
    background: #0b0d12;
  }

  .market-view {
    display: grid;
    gap: 1rem;
  }

  .market-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1rem;
  }

  .market-header__status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .market-status-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: #22c55e;
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.15);
  }

  .market-header__status strong,
  .market-header__meta strong {
    display: block;
  }

  .market-header__status span,
  .market-header__meta span {
    color: rgba(229, 231, 235, 0.68);
    font-size: 0.85rem;
  }

  .market-header__meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-left: auto;
  }

  .market-refresh {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0b0d12;
    color: #e5e7eb;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-size: 0.85rem;
    cursor: pointer;
  }

  .market-summary-title {
    padding: 0.9rem 1rem 0.45rem;
  }

  .market-summary-title h3 {
    margin: 0;
  }

  .market-summary-strip {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 1rem;
  }

  .summary-chip {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 0.9rem;
    border-radius: 14px;
    background: #0b0d12;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .summary-chip strong {
    font-size: 1rem;
  }

  .summary-state {
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.12), rgba(11, 13, 18, 0.9));
  }

  .summary-label,
  .panel-subtitle,
  .market-row span,
  .move-item span,
  .sector-card p {
    color: rgba(229, 231, 235, 0.68);
    font-size: 0.88rem;
  }

  .market-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .panel-list,
  .panel-news,
  .panel-sectors-visual,
  .panel-moves {
    padding: 1rem;
  }

  .panel-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .panel-title-row h3 {
    margin: 0;
  }

  .news-list-modern {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
  }

  .news-item {
    display: block;
    padding: 1rem;
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #141824;
  }

  .news-item:hover,
  .market-tab:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent, #3b82f6) 35%, transparent);
  }

  .news-item__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }

  .news-item h4 {
    margin: 0;
    line-height: 1.35;
  }

  .market-row,
  .move-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .market-row:last-child,
  .move-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .widget-slot-tape,
  .widget-slot-heatmap,
  .widget-slot-overview,
  .tradingview-shell--chart,
  .tradingview-widget-container,
  .tradingview-widget-container__widget,
  iframe {
    background: #0b0d12 !important;
  }

  .positive { color: #22c55e; }
  .negative { color: #ef4444; }

  .widget-slot,
  .widget-slot > script,
  .widget-slot iframe {
    width: 100%;
  }

  .widget-slot-heatmap iframe,
  .widget-slot-overview iframe {
    min-height: inherit;
  }

  .widget-slot-overview,
  .widget-slot-overview iframe,
  .widget-slot-overview > div {
    width: 100%;
    height: calc(100vh - 320px);
  }

  .widget-slot-overview iframe {
    min-height: 660px;
  }

  .full-bleed-panel .widget-slot-heatmap {
    min-height: calc(100vh - 210px);
  }

  .full-bleed-panel .widget-slot-heatmap,
  .full-bleed-panel .widget-slot-heatmap iframe,
  .full-bleed-panel .widget-slot-heatmap > div {
    width: 100%;
    height: calc(100vh - 210px);
  }

  .full-bleed-panel .widget-slot-heatmap iframe {
    min-height: 900px;
  }

  .market-symbol-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .market-ticker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.25rem;
    padding: 0.35rem 0.5rem;
    border-radius: 10px;
    background: #1a1f2a;
    color: #f8fafc;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .market-price-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
  }

  .market-row-compact strong {
    font-size: 0.98rem;
  }

  .sector-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .sector-card {
    border-radius: 14px;
    padding: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0b0d12;
    min-height: 100px;
  }

  .sector-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .sector-card p {
    margin: 0;
    line-height: 1.35;
  }

  .sector-strong {
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.10), rgba(11, 13, 18, 0.96));
  }

  .sector-positive {
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.10), rgba(11, 13, 18, 0.96));
  }

  .sector-weak {
    background: linear-gradient(180deg, rgba(239, 68, 68, 0.10), rgba(11, 13, 18, 0.96));
  }

  .move-list {
    display: grid;
    gap: 0.15rem;
  }

  @media (max-width: 1100px) {
    .market-summary-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .market-columns,
    .sector-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .market-shell {
      padding-inline: 0.75rem;
    }

    .panel-heading,
    .news-item__top {
      flex-direction: column;
      align-items: start;
    }

    .panel-title-row {
      flex-direction: column;
      align-items: start;
    }

    .widget-slot-heatmap,
    .widget-slot-overview {
      min-height: 70vh;
    }

    .full-bleed-panel .widget-slot-heatmap,
    .full-bleed-panel .widget-slot-heatmap iframe,
    .full-bleed-panel .widget-slot-heatmap > div {
      height: 72vh;
      min-height: 72vh;
    }

    .full-bleed-panel .tradingview-shell--chart,
    .full-bleed-panel .tradingview-widget-container,
    .full-bleed-panel .tradingview-widget-container__widget,
    .full-bleed-panel iframe {
      min-height: 72vh;
      height: 72vh;
    }
  }
</style>
