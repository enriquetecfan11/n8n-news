---
import { supabase } from '../lib/supabase';
import ThemeInit from '../components/ThemeInit.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = String(formData.get('email') || '');
  const password = String(formData.get('password') || '');

  const { data, error } = await supabase.auth.signInWithPassword({ email, password });
  if (error || !data.session) {
    errorMessage = error?.message || 'No se pudo iniciar sesión';
  } else {
    Astro.cookies.set('sb-access-token', data.session.access_token, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: import.meta.env.PROD,
      maxAge: data.session.expires_in,
    });
    Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: import.meta.env.PROD,
      maxAge: 60 * 60 * 24 * 30,
    });
    return Astro.redirect('/app');
  }
}
---

<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <BaseHead title={`Login - ${SITE_TITLE}`} description="Accede a tu dashboard privado" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="login-page">
    <main class="login-shell">
      <section class="login-card">
        <a class="brand" href="/">
          <span class="brand-mark">N</span>
          <span class="brand-name">{SITE_TITLE}</span>
        </a>
        <h1 class="login-title">Bienvenido de vuelta</h1>
        <p class="login-subtitle">Accede para ver tu dashboard privado y tus portfolios.</p>

        <form method="POST" class="form">
          <label>
            <span class="login-label">Email</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            <span class="login-label">Contraseña</span>
            <input name="password" type="password" autocomplete="current-password" required />
          </label>
          <button type="submit">Entrar →</button>
        </form>

        {errorMessage && <p class="error">{errorMessage}</p>}

        <p class="switch">
          ¿No tienes cuenta?
          <a href="/register">Regístrate</a>
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body.login-page) {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(37, 99, 235, 0.25), transparent 35%),
      linear-gradient(180deg, #050816 0%, #0b1120 100%);
    color: #e2e8f0;
    font-family: 'Figtree', sans-serif;
  }
  .login-shell { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
  .login-card {
    width: min(100%, 440px); padding: 2rem; border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.78); border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 30px 100px rgba(0, 0, 0, 0.35);
  }
  .brand { display: inline-flex; align-items: center; gap: .75rem; color: inherit; text-decoration: none; }
  .brand-mark { width: 2rem; height: 2rem; border-radius: .75rem; background: linear-gradient(135deg, #2563eb, #0ea5e9); display: grid; place-items: center; font-weight: 800; }
  .login-title { margin: 1.25rem 0 .5rem; font-size: 2rem; color: #ffffff; font-weight: 700; }
  .login-subtitle { color: #cbd5e1; }
  .form { display: grid; gap: 1rem; margin-top: 1.5rem; }
  label { display: grid; gap: .45rem; }
  .login-label { color: #e2e8f0; }
  input {
    border: 1px solid rgba(148, 163, 184, 0.16); background: rgba(2, 6, 23, 0.75); color: #e2e8f0;
    border-radius: .9rem; padding: .95rem 1rem;
  }
  button {
    margin-top: .5rem; border: 0; border-radius: .9rem; padding: .95rem 1rem; font-weight: 700; color: white;
    background: linear-gradient(135deg, #2563eb, #0ea5e9);
  }
  .switch { margin-top: 1rem; color: #94a3b8; }
  .switch a { color: #60a5fa; text-decoration: none; }
  .switch a:hover { color: #93c5fd; }
  .error { margin-top: 1rem; color: #fca5a5; }
</style>
