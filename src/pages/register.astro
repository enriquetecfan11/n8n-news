---
import { supabase } from '../lib/supabase';
import ThemeInit from '../components/ThemeInit.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = String(formData.get('email') || '');
  const password = String(formData.get('password') || '');
  const confirmPassword = String(formData.get('confirmPassword') || '');

  if (password !== confirmPassword) {
    errorMessage = 'Las contraseñas no coinciden';
  } else {
    const { data, error } = await supabase.auth.signUp({
      email,
      password,
      options: { emailRedirectTo: `${new URL(Astro.request.url).origin}/login` },
    });

    if (error) {
      errorMessage = error.message;
    } else if (data.session) {
      Astro.cookies.set('sb-access-token', data.session.access_token, {
        path: '/',
        httpOnly: true,
        sameSite: 'lax',
        secure: import.meta.env.PROD,
        maxAge: data.session.expires_in,
      });
      Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
        path: '/',
        httpOnly: true,
        sameSite: 'lax',
        secure: import.meta.env.PROD,
        maxAge: 60 * 60 * 24 * 30,
      });
      return Astro.redirect('/app');
    } else {
      return Astro.redirect('/login');
    }
  }
}
---

<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <BaseHead title={`Registro - ${SITE_TITLE}`} description="Crea tu cuenta" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="login-page">
    <main class="login-shell">
      <section class="login-card">
        <a class="brand" href="/">
          <span class="brand-mark">N</span>
          <span class="brand-name">{SITE_TITLE}</span>
        </a>
        <h1>Crea tu cuenta</h1>
        <p>Empieza a gestionar portfolios, mercados y noticias filtradas.</p>

        <form method="POST" class="form">
          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            <span>Contraseña</span>
            <input name="password" type="password" autocomplete="new-password" required />
          </label>
          <label>
            <span>Confirmar contraseña</span>
            <input name="confirmPassword" type="password" autocomplete="new-password" required />
          </label>
          <button type="submit">Crear cuenta →</button>
        </form>

        {errorMessage && <p class="error">{errorMessage}</p>}

        <p class="switch">
          ¿Ya tienes cuenta?
          <a href="/login">Inicia sesión</a>
        </p>
      </section>
    </main>
  </body>
</html>
