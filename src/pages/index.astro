---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Analiza tus inversiones con Inteligencia Artificial">
  <main class="landing">
    <section class="hero">
      <p class="eyebrow">SaaS financiero</p>
      <h1>Analiza tus inversiones con Inteligencia Artificial</h1>
      <p class="lead">Portfolios en tiempo real, noticias filtradas por tus activos y análisis de mercado todo en un solo lugar.</p>
      <div class="actions">
        <a class="btn primary" href="/login">Empezar gratis →</a>
        <a class="btn secondary" href="/mercados">Ver mercados</a>
      </div>
    </section>

    <section class="features">
      <article><h2>Portfolio inteligente</h2><p>Visualiza el rendimiento global y cada posición con contexto útil.</p></article>
      <article><h2>Noticias relevantes</h2><p>Filtra la información por los tickers que realmente te importan.</p></article>
      <article><h2>Mercados en tiempo real</h2><p>Sigue precios y comportamiento del mercado desde una sola interfaz.</p></article>
    </section>

    <section class="cta">
      <h2>Únete gratis hoy</h2>
      <a class="btn primary" href="/login">Crear cuenta →</a>
    </section>
  </main>
</BaseLayout>

<style>
  .landing{max-width:1400px;margin:0 auto;padding:5rem 1.5rem 4rem;color:#e2e8f0}
  .hero{padding:3rem 0 4rem}
  h1{font-size:clamp(2.6rem,6vw,5.2rem);line-height:1.02;max-width:12ch;color:#f8fafc}
  .lead{max-width:58ch;font-size:1.1rem;color:#94a3b8;margin:1rem 0 1.5rem}
  .eyebrow{color:#7dd3fc;text-transform:uppercase;letter-spacing:.18em;font-size:.8rem}
  .actions{display:flex;gap:1rem;flex-wrap:wrap}
  .btn{padding:1rem 1.25rem;border-radius:1rem;text-decoration:none;font-weight:700}
  .primary{background:linear-gradient(135deg,#2563eb,#0ea5e9);color:white}
  .secondary{background:rgba(148,163,184,.12);color:#e2e8f0}
  .features{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1rem 0 4rem}
  .features article,.cta{background:rgba(15,23,42,.78);border:1px solid rgba(148,163,184,.14);border-radius:1.25rem;padding:1.5rem}
  .features h2,.cta h2{color:#f8fafc}
  .cta{display:flex;justify-content:space-between;align-items:center;gap:1rem}
  @media (max-width:900px){.features,.cta{grid-template-columns:1fr;display:grid}.cta{justify-content:start}}
</style>
