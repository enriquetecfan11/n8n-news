---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HoldingsTable from '../../../components/portfolio/HoldingsTable.astro';
import AddTransactionModal from '../../../components/portfolio/AddTransactionModal.astro';
import {
  getCurrentSession,
  getPortfolioById,
  getTransactionsByPortfolio,
  getAssets,
} from '../../../lib/supabase';
import {
  getHoldings,
  getPriceSnapshotsForHoldings,
} from '../../../lib/portfolio';
import type { Asset, Transaction } from '../../../lib/portfolio';

const session = await getCurrentSession(Astro.cookies.get('sb-access-token')?.value);
if (!session) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/portfolio');
}

let portfolio = null;
let holdings = [];
let error: string | null = null;

try {
  portfolio = await getPortfolioById(id);

  if (!portfolio) {
    return Astro.redirect('/portfolio');
  }

  const transactions = await getTransactionsByPortfolio(id);
  const allAssets = await getAssets();
  const assetMap = new Map(allAssets.map((a: Asset) => [a.id, a]));

  holdings = getHoldings(transactions, assetMap);

  // Obtener precios actuales
  const prices = await getPriceSnapshotsForHoldings(holdings);
  holdings.forEach((h) => {
    const snapshot = prices.get(h.assetId);
    if (snapshot && snapshot.price > 0) {
      h.currentPrice = snapshot.price;
      h.currentValue = h.quantity * h.currentPrice;
      h.pnlAbsolute = h.currentValue - h.totalCost;
      h.pnlPercent = (h.pnlAbsolute / h.totalCost) * 100;
      h.priceChange24h = snapshot.change24h ?? 0;
      h.priceAvailable = true;
    } else {
      h.currentPrice = null;
      h.currentValue = 0;
      h.pnlAbsolute = 0;
      h.pnlPercent = 0;
      h.priceChange24h = 0;
      h.priceAvailable = false;
    }
  });

  // Ordenar por valor actual descendente
  holdings.sort((a, b) => b.currentValue - a.currentValue);
} catch (err) {
  console.error('Error loading assets:', err);
  error = 'Error al cargar los activos.';
}

if (!portfolio) {
  return Astro.redirect('/portfolio');
}

const totalValue = holdings.reduce((sum, h) => sum + h.currentValue, 0);
const assetOptions = holdings.map((h) => ({
  id: h.assetId,
  name: h.assetName,
  ticker: h.ticker,
}));
const byType = holdings.reduce(
  (acc, h) => {
    acc[h.type] = (acc[h.type] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);
---

<BaseLayout title={`${portfolio.name} - Activos`} description={`Activos de ${portfolio.name}`}>
  <main class="main-content">
    <div class="wrapper">
      <section class="page-header">
        <div>
          <a href={`/portfolio/${id}`} class="breadcrumb">← {portfolio.name}</a>
          <h1>Posiciones en Activos</h1>
        </div>
      </section>

      {/* Asset Statistics */}
      {holdings.length > 0 && (
        <section class="stats-section">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-label">Total de Activos</span>
              <span class="stat-value">{holdings.length}</span>
            </div>
            <div class="stat-card">
              <span class="stat-label">Valor Total</span>
              <span class="stat-value">
                {totalValue.toLocaleString('es-ES', {
                  style: 'currency',
                  currency: portfolio.base_currency,
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2,
                })}
              </span>
            </div>
            {Object.entries(byType).map(([type, count]) => (
              <div class="stat-card">
                <span class="stat-label">{type.charAt(0).toUpperCase() + type.slice(1)}</span>
                <span class="stat-value">{count}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Holdings Table */}
      {holdings.length > 0 ? (
        <section class="assets-section">
          <HoldingsTable holdings={holdings} totalValue={totalValue} portfolioId={id} />
        </section>
      ) : (
        <div class="empty-state">
          <h2>Sin activos</h2>
          <p>Este portafolio aún no tiene posiciones.</p>
        </div>
      )}
    </div>
  </main>

  <AddTransactionModal portfolioId={id} assets={assetOptions} />
</BaseLayout>

<style>
  .main-content {
    flex: 1;
    padding: var(--pf-page-pad-y) 0;
  }

  .wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--pf-page-pad-x);
  }

  .page-header {
    margin-bottom: var(--pf-section-gap);
  }

  .breadcrumb {
    display: inline-block;
    color: var(--pf-text-muted);
    text-decoration: none;
    margin-bottom: 0.2rem;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .breadcrumb:hover {
    color: var(--pf-text);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    font-weight: 700;
    color: var(--pf-text);
  }

  .stats-section {
    margin-bottom: var(--pf-section-gap);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.45rem;
  }

  .stat-card {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    padding: 0.55rem 0.7rem;
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-size: 0.68rem;
    color: var(--pf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--pf-text);
  }

  .assets-section {
    margin-bottom: var(--pf-section-gap);
  }

  .empty-state {
    text-align: center;
    padding: 0.9rem 0.8rem;
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    color: var(--pf-text-muted);
  }

  .empty-state h2 {
    margin: 0 0 0.35rem 0;
    color: var(--pf-text);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
