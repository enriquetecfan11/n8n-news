---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TransactionsTable from '../../../components/portfolio/TransactionsTable.astro';
import AddTransactionModal from '../../../components/portfolio/AddTransactionModal.astro';
import ImportTransactionsModal from '../../../components/portfolio/ImportTransactionsModal.astro';
import {
  getCurrentSession,
  getPortfolioById,
  getTransactionsByPortfolio,
  getAssets,
} from '../../../lib/supabase';
import { getHoldings } from '../../../lib/portfolio';
import type { Asset, Transaction } from '../../../lib/portfolio';

const session = await getCurrentSession(Astro.cookies.get('sb-access-token')?.value);
if (!session) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/portfolio');
}

let portfolio = null;
let transactions: Transaction[] = [];
let assets: Map<string, Asset> = new Map();
let filteredTransactions: Transaction[] = [];
let averageCostByAsset: Map<string, number> = new Map();
let holdingsByAsset: Map<string, number> = new Map();
let error: string | null = null;

try {
  portfolio = await getPortfolioById(id);

  if (!portfolio) {
    return Astro.redirect('/portfolio');
  }

  const allAssets = await getAssets();
  assets = new Map(allAssets.map((a: Asset) => [a.id, a]));

  transactions = await getTransactionsByPortfolio(id);

  const costAccumulator = new Map<string, { cost: number; quantity: number }>();
  for (const tx of transactions) {
    if (tx.type !== 'buy') continue;
    const current = costAccumulator.get(tx.asset_id) || { cost: 0, quantity: 0 };
    current.cost += tx.quantity * tx.unit_price + (tx.fee || 0);
    current.quantity += tx.quantity;
    costAccumulator.set(tx.asset_id, current);
  }

  averageCostByAsset = new Map(
    Array.from(costAccumulator.entries()).map(([assetId, value]) => [
      assetId,
      value.quantity > 0 ? value.cost / value.quantity : 0,
    ])
  );

  const holdings = getHoldings(transactions, assets);
  holdingsByAsset = new Map(holdings.map((h) => [h.assetId, h.quantity]));

  filteredTransactions = transactions;
} catch (err) {
  console.error('Error loading transactions:', err);
  error = 'Error al cargar las transacciones.';
}

if (!portfolio) {
  return Astro.redirect('/portfolio');
}

const assetOptions = Array.from(assets.values()).map((a) => ({
  id: a.id,
  name: a.name,
  ticker: a.ticker || '',
}));
---

<BaseLayout
  title={`${portfolio.name} - Transacciones`}
  description={`Historial de transacciones de ${portfolio.name}`}
>
  <main class="main-content">
    <div class="wrapper">
      <section class="page-header">
        <div>
          <a href={`/portfolio/${id}`} class="breadcrumb">← {portfolio.name}</a>
          <h1>Historial de Transacciones</h1>
        </div>
        <div class="header-actions">
          <a
            class="btn btn-secondary btn-sm"
            href={`/api/transaction/export-csv?portfolioId=${id}&format=tradingview`}
            title="Exportar transacciones en formato TradingView"
          >
            📤 Exportar TradingView
          </a>
          <button class="btn btn-secondary btn-sm" data-open-import-modal>📥 Importar CSV</button>
        </div>
      </section>

      {filteredTransactions.length > 0 ? (
        <section class="transactions-section">
          <TransactionsTable
            transactions={filteredTransactions}
            assets={assets}
            averageCostByAsset={averageCostByAsset}
            holdingsByAsset={holdingsByAsset}
            showActions={true}
            showToolbar={true}
          />
        </section>
      ) : (
        <div class="empty-state">
          <h2>No hay transacciones</h2>
          <p>Este portafolio aún no tiene transacciones registradas.</p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    flex: 1;
    padding: var(--pf-page-pad-y) 0;
  }

  .wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--pf-page-pad-x);
  }

  .page-header {
    margin-bottom: var(--pf-section-gap);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .header-actions .btn {
    text-decoration: none;
  }

  .btn-sm {
    padding: 0.35rem 0.65rem;
    font-size: 0.8rem;
  }

  .btn {
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-secondary {
    background: var(--pf-card);
    color: var(--pf-text);
    border: 1px solid var(--pf-border);
  }

  .btn-secondary:hover {
    background: #f8fafc;
  }

  .breadcrumb {
    display: inline-block;
    color: var(--pf-text-muted);
    text-decoration: none;
    margin-bottom: 0.2rem;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .breadcrumb:hover {
    color: var(--pf-text);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    font-weight: 700;
    color: var(--pf-text);
  }

  .transactions-section {
    margin-bottom: var(--pf-section-gap);
  }

  .empty-state {
    text-align: center;
    padding: 0.9rem 0.8rem;
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    color: var(--pf-text-muted);
  }

  .empty-state h2 {
    margin: 0 0 0.35rem 0;
    color: var(--pf-text);
  }
</style>

<AddTransactionModal portfolioId={id} assets={assetOptions} />

<ImportTransactionsModal portfolioId={id} />

<script>
  function initTransactionsPage() {
    const importBtn = document.querySelector('[data-open-import-modal]');

    if (importBtn) {
      importBtn.addEventListener('click', () => {
        if (window.openImportTransactionsModal) {
          window.openImportTransactionsModal();
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionsPage);
  } else {
    initTransactionsPage();
  }
</script>
