---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TransactionsTable from '../../../components/portfolio/TransactionsTable.astro';
import EditTransactionModal from '../../../components/portfolio/EditTransactionModal.astro';
import ImportTransactionsModal from '../../../components/portfolio/ImportTransactionsModal.astro';
import {
  getCurrentSession,
  getPortfolioById,
  getTransactionsByPortfolio,
  getAssets,
} from '../../../lib/supabase';
import type { Asset, Transaction } from '../../../lib/portfolio';

const session = await getCurrentSession(Astro.cookies.get('sb-access-token')?.value);
if (!session) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/portfolio');
}

let portfolio = null;
let transactions: Transaction[] = [];
let assets: Map<string, Asset> = new Map();
let filteredTransactions: Transaction[] = [];
let averageCostByAsset: Map<string, number> = new Map();
let error: string | null = null;

const typeFilter = new URL(Astro.request.url).searchParams.get('type');
const assetFilter = new URL(Astro.request.url).searchParams.get('asset');

try {
  portfolio = await getPortfolioById(id);

  if (!portfolio) {
    return Astro.redirect('/portfolio');
  }

  const allAssets = await getAssets();
  assets = new Map(allAssets.map((a: Asset) => [a.id, a]));

  transactions = await getTransactionsByPortfolio(id);

  const costAccumulator = new Map<string, { cost: number; quantity: number }>();
  for (const tx of transactions) {
    if (tx.type !== 'buy') continue;
    const current = costAccumulator.get(tx.asset_id) || { cost: 0, quantity: 0 };
    current.cost += tx.quantity * tx.unit_price + (tx.fee || 0);
    current.quantity += tx.quantity;
    costAccumulator.set(tx.asset_id, current);
  }

  averageCostByAsset = new Map(
    Array.from(costAccumulator.entries()).map(([assetId, value]) => [
      assetId,
      value.quantity > 0 ? value.cost / value.quantity : 0,
    ])
  );

  // Aplicar filtros
  filteredTransactions = transactions.filter((tx) => {
    if (typeFilter && tx.type !== typeFilter) return false;
    if (assetFilter && tx.asset_id !== assetFilter) return false;
    return true;
  });
} catch (err) {
  console.error('Error loading transactions:', err);
  error = 'Error al cargar las transacciones.';
}

if (!portfolio) {
  return Astro.redirect('/portfolio');
}

// Get unique types and assets for filters
const types = Array.from(new Set(transactions.map((t) => t.type)));
const assetIds = Array.from(new Set(transactions.map((t) => t.asset_id)));
---

<BaseLayout
  title={`${portfolio.name} - Transacciones`}
  description={`Historial de transacciones de ${portfolio.name}`}
>
  <main class="main-content">
    <div class="wrapper">
      <section class="page-header">
        <div>
          <a href={`/portfolio/${id}`} class="breadcrumb">← {portfolio.name}</a>
          <h1>Historial de Transacciones</h1>
        </div>
        <button class="btn btn-secondary btn-sm" data-open-import-modal style="align-self: flex-start;">📥 Importar CSV</button>
      </section>

      {/* Filters */}
      {(types.length > 0 || assetIds.length > 0) && (
        <section class="filters-section">
          <div class="filters-grid">
            {types.length > 0 && (
              <div class="filter-group">
                <label htmlFor="type-filter">Tipo de Transacción:</label>
                <select id="type-filter" onchange="window.location.href = this.value">
                  <option value={`/portfolio/${id}/transactions`}>Todos</option>
                  {types.map((type) => (
                    <option value={`/portfolio/${id}/transactions?type=${type}`} selected={typeFilter === type}>
                      {type === 'buy' ? 'Compras' : type === 'sell' ? 'Ventas' : type === 'dividend' ? 'Dividendos' : 'Comisiones'}
                    </option>
                  ))}
                </select>
              </div>
            )}

            {assetIds.length > 0 && (
              <div class="filter-group">
                <label htmlFor="asset-filter">Activo:</label>
                <select id="asset-filter" onchange="window.location.href = this.value">
                  <option value={`/portfolio/${id}/transactions`}>Todos</option>
                  {assetIds.map((assetId) => {
                    const asset = assets.get(assetId);
                    if (!asset) return null;
                    return (
                      <option value={`/portfolio/${id}/transactions?asset=${assetId}`} selected={assetFilter === assetId}>
                        {asset.name} ({asset.ticker})
                      </option>
                    );
                  })}
                </select>
              </div>
            )}
          </div>
        </section>
      )}

      {/* Transactions Table */}
      {filteredTransactions.length > 0 ? (
        <section class="transactions-section">
          <div class="stats-summary">
            <span class="stat">{filteredTransactions.length} transacciones</span>
            {filteredTransactions.length !== transactions.length && (
              <span class="stat">({transactions.length} total)</span>
            )}
          </div>
          <TransactionsTable
            transactions={filteredTransactions}
            assets={assets}
            averageCostByAsset={averageCostByAsset}
            showDelete={true}
          />
        </section>
      ) : (
        <div class="empty-state">
          <h2>No hay transacciones</h2>
          {typeFilter || assetFilter ? (
            <p>No se encontraron transacciones con los filtros aplicados.</p>
          ) : (
            <p>Este portafolio aún no tiene transacciones registradas.</p>
          )}
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    flex: 1;
    padding: var(--pf-page-pad-y) 0;
  }

  .wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--pf-page-pad-x);
  }

  .page-header {
    margin-bottom: var(--pf-section-gap);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .btn-sm {
    padding: 0.35rem 0.65rem;
    font-size: 0.8rem;
  }

  .btn {
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-secondary {
    background: var(--pf-card);
    color: var(--pf-text);
    border: 1px solid var(--pf-border);
  }

  .btn-secondary:hover {
    background: #f8fafc;
  }

  .breadcrumb {
    display: inline-block;
    color: var(--pf-text-muted);
    text-decoration: none;
    margin-bottom: 0.2rem;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .breadcrumb:hover {
    color: var(--pf-text);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    font-weight: 700;
    color: var(--pf-text);
  }

  .filters-section {
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    padding: 0.6rem 0.75rem;
    margin-bottom: var(--pf-section-gap);
  }

  .filters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.45rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
  }

  .filter-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--pf-text-muted);
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .filter-group select {
    padding: 0.42rem 0.65rem;
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-md);
    background: #ffffff;
    color: var(--pf-text);
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .filter-group select:hover {
    border-color: #94a3b8;
  }

  .filter-group select:focus {
    outline: none;
    border-color: #2563eb;
  }

  .transactions-section {
    margin-bottom: var(--pf-section-gap);
  }

  .stats-summary {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.35rem;
    font-size: 0.8rem;
    color: var(--pf-text-muted);
  }

  .stat {
    padding: 0.2rem 0.45rem;
    background: #f8fafc;
    border-radius: var(--radius-sm);
  }

  .empty-state {
    text-align: center;
    padding: 0.9rem 0.8rem;
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    color: var(--pf-text-muted);
  }

  .empty-state h2 {
    margin: 0 0 0.35rem 0;
    color: var(--pf-text);
  }

  @media (max-width: 768px) {
    .filters-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<EditTransactionModal />

<ImportTransactionsModal portfolioId={id} />

<script>
  function initTransactionsPage() {
    const importBtn = document.querySelector('[data-open-import-modal]');

    if (importBtn) {
      importBtn.addEventListener('click', () => {
        if (window.openImportTransactionsModal) {
          window.openImportTransactionsModal();
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionsPage);
  } else {
    initTransactionsPage();
  }
</script>
