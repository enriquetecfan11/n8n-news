---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortfolioPositionsTable from '../../../components/portfolio/PortfolioPositionsTable.astro';
import AddTransactionModal from '../../../components/portfolio/AddTransactionModal.astro';
import ImportTransactionsModal from '../../../components/portfolio/ImportTransactionsModal.astro';
import {
  getCurrentSession,
  getPortfolioById,
  getTransactionsByPortfolio,
  getAssets,
} from '../../../lib/supabase';
import {
  getHoldings,
  getPortfolioSummary,
  getPriceSnapshotsForHoldings,
  buildPositionRows,
} from '../../../lib/portfolio';
import type { Asset, PositionRow, Portfolio, Transaction } from '../../../lib/portfolio';

const session = await getCurrentSession(Astro.cookies.get('sb-access-token')?.value);
if (!session) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/portfolio');
}

let portfolio: Portfolio | null = null;
let transactions: Transaction[] = [];
let assets: Map<string, Asset> = new Map();
let positionRows: PositionRow[] = [];
let error: string | null = null;

try {
  portfolio = await getPortfolioById(id);

  if (!portfolio) {
    return Astro.redirect('/portfolio');
  }

  const allAssets = await getAssets();
  assets = new Map(allAssets.map((a: Asset) => [a.id, a]));

  transactions = await getTransactionsByPortfolio(id);
  let holdings = getHoldings(transactions, assets);

  const prices = await getPriceSnapshotsForHoldings(holdings);
  holdings.forEach((holding) => {
    const snapshot = prices.get(holding.assetId);
    if (snapshot && typeof snapshot.price === 'number' && snapshot.price > 0) {
      holding.currentPrice = snapshot.price;
      holding.currentValue = holding.quantity * holding.currentPrice;
      holding.pnlAbsolute = holding.currentValue - holding.totalCost;
      holding.pnlPercent = holding.totalCost > 0 ? (holding.pnlAbsolute / holding.totalCost) * 100 : 0;
      holding.priceChange24h = snapshot.change24h ?? 0;
      holding.priceAvailable = true;
    } else {
      holding.priceAvailable = false;
    }
  });

  const summary = getPortfolioSummary(holdings);
  positionRows = buildPositionRows(holdings, transactions, assets, summary.totalValue);
} catch (err) {
  console.error('Error loading transactions:', err);
  error = 'Error al cargar las transacciones.';
}

if (!portfolio) {
  return Astro.redirect('/portfolio');
}

const portfolioData = portfolio;
const assetOptions = Array.from(assets.values()).map((a) => ({
  id: a.id,
  name: a.name,
  ticker: a.ticker || '',
}));
---

<BaseLayout
  title={`${portfolioData.name} - Transacciones`}
  description={`Posiciones y métricas de ${portfolioData.name}`}
>
  <main class="main-content">
    <div class="wrapper">
      <section class="page-header">
        <div>
          <a href={`/portfolio/${id}`} class="breadcrumb">← {portfolioData.name}</a>
          <h1>Transacciones</h1>
          <p class="page-subtitle">Vista por posición con reparto, P&amp;L y dividendos acumulados</p>
        </div>
        <div class="header-actions">
          <a
            class="btn btn-secondary btn-sm"
            href={`/api/transaction/export-csv?portfolioId=${id}&format=tradingview`}
            title="Exportar transacciones en formato TradingView"
          >
            📤 Exportar TradingView
          </a>
          <button class="btn btn-secondary btn-sm" data-open-import-modal>📥 Importar CSV</button>
        </div>
      </section>

      {positionRows.length > 0 ? (
        <section class="transactions-section">
          <PortfolioPositionsTable positions={positionRows} showToolbar={true} />
        </section>
      ) : (
        <div class="empty-state">
          <h2>No hay posiciones</h2>
          <p>Este portafolio aún no tiene activos con posición abierta.</p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    flex: 1;
    padding: var(--pf-page-pad-y) 0;
  }

  .wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--pf-page-pad-x);
  }

  .page-header {
    margin-bottom: var(--pf-section-gap);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .header-actions .btn {
    text-decoration: none;
  }

  .btn-sm {
    padding: 0.35rem 0.65rem;
    font-size: 0.8rem;
  }

  .btn {
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-secondary {
    background: var(--pf-card);
    color: var(--pf-text);
    border: 1px solid var(--pf-border);
  }

  .btn-secondary:hover {
    background: #f8fafc;
  }

  .breadcrumb {
    display: inline-block;
    color: var(--pf-text-muted);
    text-decoration: none;
    margin-bottom: 0.2rem;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .breadcrumb:hover {
    color: var(--pf-text);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    font-weight: 700;
    color: var(--pf-text);
  }

  .page-subtitle {
    margin: 0.35rem 0 0;
    color: var(--pf-text-muted);
    font-size: 0.9rem;
  }

  .transactions-section {
    margin-bottom: var(--pf-section-gap);
  }

  .empty-state {
    text-align: center;
    padding: 0.9rem 0.8rem;
    background: var(--pf-card);
    border: 1px solid var(--pf-border);
    border-radius: var(--radius-xl);
    color: var(--pf-text-muted);
  }

  .empty-state h2 {
    margin: 0 0 0.35rem 0;
    color: var(--pf-text);
  }
</style>

<AddTransactionModal portfolioId={id} assets={assetOptions} />

<ImportTransactionsModal portfolioId={id} />

<script>
  function initTransactionsPage() {
    const importBtn = document.querySelector('[data-open-import-modal]');

    if (importBtn) {
      importBtn.addEventListener('click', () => {
        if (window.openImportTransactionsModal) {
          window.openImportTransactionsModal();
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionsPage);
  } else {
    initTransactionsPage();
  }
</script>
