---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DistributionDonut from '../../components/portfolio/charts/DistributionDonut';
import PnlBarChart from '../../components/portfolio/charts/PnlBarChart';
import WeightBarChart from '../../components/portfolio/charts/WeightBarChart';
import HoldingsTable from '../../components/portfolio/HoldingsTable.astro';
import TransactionsTable from '../../components/portfolio/TransactionsTable.astro';
import EditPortfolioModal from '../../components/portfolio/EditPortfolioModal.astro';
import BuyAssetModal from '../../components/portfolio/BuyAssetModal.astro';
import AddTransactionModal from '../../components/portfolio/AddTransactionModal.astro';
import ImportTransactionsModal from '../../components/portfolio/ImportTransactionsModal.astro';
import {
  getCurrentSession,
  getPortfolioById,
  getTransactionsByPortfolio,
  getAssets,
} from '../../lib/supabase';
import {
  getHoldings,
  getPortfolioSummary,
  formatCurrency,
  formatPercent,
  getPriceSnapshotsForHoldings,
} from '../../lib/portfolio';
import type { Asset, Holding, Portfolio, PortfolioSummary, Transaction } from '../../lib/portfolio';

const session = await getCurrentSession(Astro.cookies.get('sb-access-token')?.value);
if (!session) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/portfolio');
}

let portfolio!: Portfolio;
let holdings: Holding[] = [];
let summary!: PortfolioSummary;
let allTransactions: Transaction[] = [];
let assets: Asset[] = [];
let error: string | null = null;
let holdingsByPnL: Holding[] = [];
let bestPosition: Holding | null = null;
let worstPosition: Holding | null = null;
let positivePositions = 0;
let negativePositions = 0;
let topPositionByWeight: Holding | null = null;
let dividendTransactions: Transaction[] = [];
let totalDividendAmount = 0;
let averageCostByAsset: Map<string, number> = new Map();
let holdingsByAsset: Map<string, number> = new Map();
const typeColors: Record<string, string> = {
  stock: '#6366f1',
  etf: '#8b5cf6',
  crypto: '#f97316',
  cash: '#64748b',
};
const serverTime = new Intl.DateTimeFormat('es-ES', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
}).format(new Date());
let distributionChartData: Array<{ type: string; value: number; color: string; pct: string }> = [];
let pnlChartData: Array<{ name: string; ticker: string; pnl: number }> = [];
let weightChartData: Array<{ name: string; ticker: string; weight: number }> = [];
let hasDistributionData = false;
let singleDistributionType: [string, { value: number; percent: number }] | null = null;

try {
  portfolio = await getPortfolioById(id);

  if (!portfolio) {
    return Astro.redirect('/portfolio');
  }

  const transactions: Transaction[] = await getTransactionsByPortfolio(id);
  allTransactions = transactions;
  assets = await getAssets();
  const assetMap = new Map(assets.map((a: Asset) => [a.id, a]));

  holdings = getHoldings(transactions, assetMap);
  holdingsByAsset = new Map(holdings.map((h) => [h.assetId, h.quantity]));

  const costAccumulator = new Map<string, { cost: number; quantity: number }>();
  for (const tx of transactions) {
    if (tx.type !== 'buy') continue;
    const current = costAccumulator.get(tx.asset_id) || { cost: 0, quantity: 0 };
    current.cost += tx.quantity * tx.unit_price + (tx.fee || 0);
    current.quantity += tx.quantity;
    costAccumulator.set(tx.asset_id, current);
  }
  averageCostByAsset = new Map(
    Array.from(costAccumulator.entries()).map(([assetId, value]) => [
      assetId,
      value.quantity > 0 ? value.cost / value.quantity : 0,
    ])
  );

  summary = getPortfolioSummary(holdings);

  // Obtener precios actuales (server-side)
  const prices = await getPriceSnapshotsForHoldings(holdings);
  holdings.forEach((h) => {
    const snapshot = prices.get(h.assetId);
    if (snapshot && typeof snapshot.price === 'number' && snapshot.price > 0) {
      h.currentPrice = snapshot.price;
      h.currentValue = h.quantity * h.currentPrice;
      h.pnlAbsolute = h.currentValue - h.totalCost;
      h.pnlPercent = (h.pnlAbsolute / h.totalCost) * 100;
      h.priceChange24h = snapshot.change24h ?? 0;
      h.priceAvailable = true;
    } else {
      h.currentPrice = null;
      h.currentValue = 0;
      h.pnlAbsolute = 0;
      h.pnlPercent = 0;
      h.priceChange24h = 0;
      h.priceAvailable = false;
    }
  });

  // Recalcular resumen con precios actuales
  summary = getPortfolioSummary(holdings);
  holdingsByPnL = [...holdings].sort((a, b) => b.pnlPercent - a.pnlPercent);
  bestPosition = holdingsByPnL[0] || null;
  worstPosition = holdingsByPnL[holdingsByPnL.length - 1] || null;
  positivePositions = holdings.filter((h) => h.pnlAbsolute >= 0).length;
  negativePositions = holdings.filter((h) => h.pnlAbsolute < 0).length;
  topPositionByWeight = [...holdings].sort((a, b) => b.currentValue - a.currentValue)[0] || null;
  dividendTransactions = transactions.filter((tx) => tx.type === 'dividend');
  totalDividendAmount = dividendTransactions.reduce((sum, tx) => sum + tx.quantity * tx.unit_price + (tx.fee || 0), 0);
  distributionChartData = Object.entries(summary.byType).map(([type, data]) => ({
    type,
    value: data.value,
    pct: data.percent.toFixed(1),
    color: typeColors[type] || '#64748b',
  }));
  hasDistributionData = Object.keys(summary.byType).length > 0;
  singleDistributionType = hasDistributionData && Object.keys(summary.byType).length === 1 ? (Object.entries(summary.byType)[0] as [string, { value: number; percent: number }]) : null;
  pnlChartData = [...holdings]
    .sort((a, b) => b.pnlPercent - a.pnlPercent)
    .map((h) => ({
      name: h.assetName,
      ticker: h.ticker,
      pnl: h.pnlPercent,
    }));
  weightChartData = [...holdings]
    .sort((a, b) => b.currentValue - a.currentValue)
    .map((h) => ({
      name: h.assetName,
      ticker: h.ticker,
      weight: summary.totalValue > 0 ? (h.currentValue / summary.totalValue) * 100 : 0,
    }));

} catch (err) {
  console.error('Error loading portfolio:', err);
  error = 'Error al cargar el portafolio. Por favor, verifica la conexión a Supabase.';
}

if (error || !portfolio || !summary) {
  return Astro.redirect('/portfolio');
}

const assetOptions = assets.map((a) => ({
  id: a.id,
  name: a.name,
  ticker: a.ticker || '',
}));
---

<BaseLayout title={portfolio.name} description={portfolio.description || 'Detalle del portafolio'}>
  <main class="main-content portfolio-section">
    <div class="wrapper">
      <section class="portfolio-hero">
        <div class="portfolio-hero-copy">
          <a href="/portfolio" class="breadcrumb">← Portafolios</a>
          <div class="portfolio-hero-title-row">
            <div>
              <h1>{portfolio.name}</h1>
              {portfolio.description && <p class="subtitle">{portfolio.description}</p>}
            </div>
            <span class="currency-badge">{portfolio.base_currency}</span>
          </div>
          <div class="portfolio-hero-tags">
            <span class="hero-tag">{holdings.length} activos</span>
            <span class="hero-tag">{positivePositions} en verde</span>
            <span class="hero-tag">{negativePositions} en rojo</span>
            <span class="hero-tag">{dividendTransactions.length} dividendos</span>
          </div>
        </div>

        <div class="portfolio-hero-panel">
          <div class="hero-panel-top">
            <span class="hero-panel-label">Ganancia neta</span>
            <span class="hero-panel-time">Actualizado {serverTime}</span>
          </div>
          <div class:list={['hero-panel-value', summary.pnlAbsolute >= 0 ? 'is-positive' : 'is-negative']}>
            {formatCurrency(summary.pnlAbsolute, portfolio.base_currency)}
          </div>
          <div class="hero-panel-subvalue">
            {formatPercent(summary.pnlPercent)} sobre {formatCurrency(summary.totalCost, portfolio.base_currency)}
          </div>
          <div class="hero-metrics">
            <div class="hero-metric">
              <span class="hero-metric-label">Valor actual</span>
              <span class="hero-metric-value">{formatCurrency(summary.totalValue, portfolio.base_currency)}</span>
            </div>
            <div class="hero-metric">
              <span class="hero-metric-label">Coste base</span>
              <span class="hero-metric-value">{formatCurrency(summary.totalCost, portfolio.base_currency)}</span>
            </div>
          </div>
        </div>
      </section>

      <section class="portfolio-actions" aria-label="Acciones del portafolio">
        <div class="portfolio-actions-left">
          <span class="actions-note">Capital en {portfolio.base_currency}</span>
          <span class="actions-separator">·</span>
          <span class="actions-note">Precios sincronizados a las {serverTime}</span>
        </div>
        <div class="portfolio-actions-right">
          <button class="bar-btn bar-btn-primary" onclick="document.getElementById('modal-comprar-activo').classList.remove('hidden')" title="Comprar activo">
            Comprar activo
          </button>
          <details class="bar-menu">
            <summary class="bar-btn bar-btn-secondary" title="Más acciones">Acciones</summary>
            <div class="bar-menu-panel">
              <a
                class="bar-menu-item"
                href={`/api/transaction/export-csv?portfolioId=${id}&format=tradingview`}
                title="Exportar transacciones para TradingView Paper Trading"
              >
                Exportar TradingView
              </a>
              <button class="bar-menu-item" data-open-import-modal title="Importar transacciones desde CSV">Importar</button>
              <button class="bar-menu-item" data-refresh-prices title="Actualizar precios actuales">Actualizar</button>
              <button class="bar-menu-item" data-open-edit-portfolio-modal title="Editar información del portafolio">Editar</button>
              <button class="bar-menu-item bar-menu-item-danger" data-delete-portfolio data-portfolio-id={id} title="Eliminar portafolio permanentemente">Eliminar</button>
            </div>
          </details>
        </div>
      </section>

      <section class="tabs-section">
        <div class="tabs-header">
          <nav class="tabs-nav" aria-label="Secciones del portafolio">
            <button type="button" data-tab="resumen" class="tab-btn tab-active">
              <span class="tab-label">Resumen</span>
            </button>
            <button type="button" data-tab="posiciones" class="tab-btn">
              <span class="tab-label">Posiciones</span>
              <span class="tab-badge">{holdings.length}</span>
            </button>
            <button type="button" data-tab="transacciones" class="tab-btn">
              <span class="tab-label">Transacciones</span>
              <span class="tab-badge">{allTransactions.length}</span>
            </button>
            <button type="button" data-tab="activos" class="tab-btn">
              <span class="tab-label">Activos</span>
              <span class="tab-badge">{assets.length}</span>
            </button>
            <button type="button" data-tab="analisis" class="tab-btn">
              <span class="tab-label">Análisis</span>
            </button>
            <button type="button" data-tab="dividendos" class="tab-btn">
              <span class="tab-label">Dividendos</span>
              <span class="tab-badge">{dividendTransactions.length}</span>
            </button>
          </nav>
        </div>

        <div data-panel="resumen" class="tab-panel">
          <div class="summary-topline">
            <div class="summary-title-wrap">
              <h2 class="summary-title">Resumen de cartera</h2>
              <div class="summary-meta-line">
                <span>{formatCurrency(summary.totalCost, portfolio.base_currency)} invertidos</span>
                <span class="summary-dot">·</span>
                <span>{holdings.length} activos</span>
              </div>
            </div>
            <span class="summary-updated">
              <svg viewBox="0 0 24 24" aria-hidden="true" class="summary-sync-icon">
                <path d="M12 5V2L8 6l4 4V7c2.76 0 5 2.24 5 5 0 1.03-.31 2-.84 2.82l1.46 1.46A6.95 6.95 0 0 0 19 12c0-3.87-3.13-7-7-7Zm0 12c-2.76 0-5-2.24-5-5 0-1.03.31-2 .84-2.82L6.38 7.72A6.95 6.95 0 0 0 5 12c0 3.87 3.13 7 7 7v3l4-4-4-4v3Z" fill="currentColor" />
              </svg>
              <span>Precios actualizados: {serverTime}</span>
            </span>
          </div>
          <div class="summary-layout">
            <div class="summary-left">
              <section class="summary-section summary-strip">
                <div class="summary-metric summary-metric-featured">
                  <span class="summary-metric-label">P&amp;L absoluto</span>
                  <span class:list={['summary-metric-value', 'summary-metric-large', summary.pnlAbsolute >= 0 ? 'is-positive' : 'is-negative']}>{formatCurrency(summary.pnlAbsolute, portfolio.base_currency)}</span>
                  <span class:list={['summary-metric-foot', summary.pnlPercent >= 0 ? 'is-positive' : 'is-negative']}>{formatPercent(summary.pnlPercent)} de rentabilidad</span>
                </div>
                <div class="summary-metric">
                  <span class="summary-metric-label">Valor actual</span>
                  <span class="summary-metric-value">{formatCurrency(summary.totalValue, portfolio.base_currency)}</span>
                  <span class="summary-metric-foot">Precio de mercado</span>
                </div>
                <div class="summary-metric">
                  <span class="summary-metric-label">Coste base</span>
                  <span class="summary-metric-value">{formatCurrency(summary.totalCost, portfolio.base_currency)}</span>
                  <span class="summary-metric-foot">Capital aportado</span>
                </div>
                <div class="summary-metric">
                  <span class="summary-metric-label">Cobertura</span>
                  <span class="summary-metric-value">{positivePositions + negativePositions}</span>
                  <span class="summary-metric-foot">{positivePositions} verdes · {negativePositions} rojas</span>
                </div>
              </section>

              <div class="best-worst-grid">
                <section class="summary-section position-line position-line-positive">
                  <div class="position-line-label">Mejor posición</div>
                  <div class="position-line-body">
                    <div class="position-line-main">
                      <div class="position-line-name">{bestPosition ? bestPosition.assetName : '-'}</div>
                      <div class="position-line-ticker">{bestPosition ? bestPosition.ticker : '-'}</div>
                    </div>
                    <div class="position-line-right">
                      <div class="position-line-pnl position-line-pnl-positive">{bestPosition ? formatPercent(bestPosition.pnlPercent) : '-'}</div>
                      <div class="position-line-eur">{bestPosition ? formatCurrency(bestPosition.pnlAbsolute, portfolio.base_currency) : '-'}</div>
                    </div>
                  </div>
                </section>
                <section class="summary-section position-line position-line-negative">
                  <div class="position-line-label">Peor posición</div>
                  <div class="position-line-body">
                    <div class="position-line-main">
                      <div class="position-line-name">{worstPosition ? worstPosition.assetName : '-'}</div>
                      <div class="position-line-ticker">{worstPosition ? worstPosition.ticker : '-'}</div>
                    </div>
                    <div class="position-line-right">
                      <div class="position-line-pnl position-line-pnl-negative">{worstPosition ? formatPercent(worstPosition.pnlPercent) : '-'}</div>
                      <div class="position-line-eur">{worstPosition ? formatCurrency(worstPosition.pnlAbsolute, portfolio.base_currency) : '-'}</div>
                    </div>
                  </div>
                </section>
              </div>
            </div>

            <div class="summary-right">
              <section class="summary-section summary-chart-section">
                <div class="section-header">
                  <h2>Distribución</h2>
                  <span class="section-meta">Por tipo de activo</span>
                </div>
                <div class="summary-distribution">
                  {singleDistributionType ? (
                    <div class="summary-single-distribution">
                      <div class="summary-single-distribution-row">
                        <span class="summary-single-distribution-label">Tipo dominante</span>
                        <span class="summary-single-distribution-value">{singleDistributionType[0].charAt(0).toUpperCase() + singleDistributionType[0].slice(1)}</span>
                        <span class="summary-single-distribution-amount">{formatCurrency(singleDistributionType[1].value, portfolio.base_currency)}</span>
                      </div>
                      <div class="summary-single-distribution-row summary-single-distribution-row-foot">
                        <span>{singleDistributionType[1].percent.toFixed(1)}% de la cartera</span>
                        <span>{holdings.length} activo{holdings.length === 1 ? '' : 's'}</span>
                      </div>
                    </div>
                  ) : (
                    <DistributionDonut client:load data={distributionChartData} compact={true} />
                  )}
                </div>
              </section>

              <section class="summary-section summary-insight-card">
                <div class="section-header">
                  <h2>Lectura rápida</h2>
                  <span class="section-meta">Ganancias y riesgo</span>
                </div>
                <div class="insight-list">
                  <div class="insight-row">
                    <span class="insight-label">Posiciones ganadoras</span>
                    <span class="insight-value is-positive">{positivePositions}</span>
                  </div>
                  <div class="insight-row">
                    <span class="insight-label">Posiciones perdedoras</span>
                    <span class="insight-value is-negative">{negativePositions}</span>
                  </div>
                  <div class="insight-row">
                    <span class="insight-label">Dividendos</span>
                    <span class="insight-value">{formatCurrency(totalDividendAmount, portfolio.base_currency)}</span>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </div>

        <div data-panel="posiciones" class="tab-panel hidden">
          {holdings.length > 0 ? (
            <section class="holdings-section">
              <HoldingsTable holdings={holdings} totalValue={summary.totalValue} portfolioId={id} />
            </section>
          ) : (
            <div class="empty-state">
              <h2>Sin activos</h2>
              <p>Este portafolio aún no tiene posiciones. Añade transacciones para comenzar.</p>
            </div>
          )}
        </div>

        <div data-panel="transacciones" class="tab-panel hidden">
          {allTransactions.length > 0 ? (
            <section class="transactions-section">
              <TransactionsTable
                transactions={allTransactions}
                assets={new Map(assets.map((a: Asset) => [a.id, a]))}
                averageCostByAsset={averageCostByAsset}
                holdingsByAsset={holdingsByAsset}
                showActions={true}
                showToolbar={true}
              />
            </section>
          ) : (
            <div class="empty-state">
              <h2>Sin transacciones</h2>
              <p>Este portafolio todavía no registra operaciones.</p>
            </div>
          )}
        </div>

        <div data-panel="activos" class="tab-panel hidden">
          {holdings.length > 0 ? (
            <section class="assets-list-section">
              <div class="assets-list">
                {holdings.map((holding) => (
                  <div class="asset-row">
                    <div class="asset-row-main">
                      <div class="asset-row-title" title={holding.assetName}>{holding.assetName}</div>
                      <span class:list={['holding-badge', holding.type]}>{holding.ticker}</span>
                    </div>
                    <div class="asset-row-meta">
                      <span>{holding.quantity.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 8 })}</span>
                      <span>{formatCurrency(holding.currentValue, portfolio.base_currency)}</span>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ) : (
            <div class="empty-state">
              <h2>Sin activos</h2>
              <p>No hay posiciones para mostrar en este portafolio.</p>
            </div>
          )}
        </div>

        <div data-panel="analisis" class="tab-panel hidden">
          <section class="summary-section">
            <div class="section-header">
              <h2>Comparativa</h2>
              <span class="section-meta">Ordenado por P&amp;L %</span>
            </div>
            <div class="analysis-table">
              {holdingsByPnL.map((holding) => (
                <div class="analysis-row">
                  <div class="analysis-main">
                    <span class="analysis-name">{holding.assetName}</span>
                    <span class="analysis-ticker">{holding.ticker}</span>
                  </div>
                  <span class={holding.pnlPercent >= 0 ? 'analysis-positive' : 'analysis-negative'}>{formatPercent(holding.pnlPercent)}</span>
                </div>
              ))}
            </div>
          </section>

          <section class="summary-section">
            <div class="section-header">
              <h2>Concentración</h2>
              <span class="section-meta">% sobre el total</span>
            </div>
            <WeightBarChart client:load data={weightChartData} />
          </section>

          <section class="summary-section">
            <div class="section-header">
              <h2>Rentabilidad por activo</h2>
              <span class="section-meta">P&amp;L % comparado</span>
            </div>
            <PnlBarChart client:load data={pnlChartData} />
          </section>

          <section class="summary-section">
            <div class="section-header">
              <h2>Métricas</h2>
            </div>
            <div class="summary-table">
              <div class="summary-row">
                <span class="summary-key">Activo más rentable</span>
                <span class="summary-val">{bestPosition ? bestPosition.assetName : '-'}</span>
              </div>
              <div class="summary-row">
                <span class="summary-key">Activo con más peso</span>
                <span class="summary-val">{topPositionByWeight ? topPositionByWeight.assetName : '-'}</span>
              </div>
              <div class="summary-row">
                <span class="summary-key">Posiciones en positivo</span>
                <span class="summary-val">{positivePositions}</span>
              </div>
              <div class="summary-row">
                <span class="summary-key">Posiciones en negativo</span>
                <span class="summary-val">{negativePositions}</span>
              </div>
            </div>
          </section>
        </div>

        <div data-panel="dividendos" class="tab-panel hidden">
          {dividendTransactions.length > 0 ? (
            <section class="summary-section">
              <div class="analysis-table">
                <div class="analysis-row analysis-head">
                  <span>Fecha</span>
                  <span>Activo</span>
                  <span>Importe</span>
                </div>
                {dividendTransactions.map((tx) => {
                  const asset = assets.find((a) => a.id === tx.asset_id);
                  const amount = tx.quantity * tx.unit_price + (tx.fee || 0);
                  return (
                    <div class="analysis-row">
                      <span>{new Date(tx.date).toLocaleDateString('es-ES')}</span>
                      <span>{asset ? `${asset.name} (${asset.ticker})` : 'Desconocido'}</span>
                      <span>{formatCurrency(amount, portfolio.base_currency)}</span>
                    </div>
                  );
                })}
              </div>
              <div class="summary-row" style="margin-top: 0.75rem;">
                <span class="summary-key">Total acumulado</span>
                <span class="summary-val">{formatCurrency(totalDividendAmount, portfolio.base_currency)}</span>
              </div>
            </section>
          ) : (
            <div class="empty-state">
              <h2>Sin dividendos registrados aún</h2>
            </div>
          )}
        </div>
      </section>
    </div>
  </main>

  <BuyAssetModal portfolioId={id} />

  <AddTransactionModal portfolioId={id} assets={assetOptions} />

  <EditPortfolioModal
    portfolioId={id}
    portfolioName={portfolio.name}
    portfolioDescription={portfolio.description || undefined}
    portfolioCurrency={portfolio.base_currency}
  />

  <AddTransactionModal portfolioId={id} assets={assetOptions} />

  <ImportTransactionsModal portfolioId={id} />
</BaseLayout>

<script define:vars={{ portfolioId: id }}>
  function initPortfolioDashboard() {
    const deleteBtn = document.querySelector('[data-delete-portfolio]');
    const importBtn = document.querySelector('[data-open-import-modal]');
    const refreshBtn = document.querySelector('[data-refresh-prices]');

    if (importBtn) {
      importBtn.addEventListener('click', () => {
        if (window.openImportTransactionsModal) {
          window.openImportTransactionsModal();
        }
      });
    }

    if (refreshBtn) {
      refreshBtn.addEventListener('click', () => {
        refreshBtn.disabled = true;
        refreshBtn.textContent = '🔄 Actualizando...';
        // Reload with cache busting
        window.location.href = window.location.href + '?refresh=' + Date.now();
      });
    }

    if (deleteBtn) {
      deleteBtn.addEventListener('click', async () => {
        if (!confirm('¿Estás seguro de que deseas eliminar este portafolio? Se eliminarán todas sus transacciones.')) {
          return;
        }

        try {
          const response = await fetch('/api/portfolio/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: portfolioId }),
          });

          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Error desconocido');
          }

          alert('Portafolio eliminado correctamente');
          window.location.href = '/portfolio';
        } catch (error) {
          alert(`Error: ${error instanceof Error ? error.message : 'Error al eliminar'}`);
        }
      });
    }

    const tabButtons = document.querySelectorAll('[data-tab]');
    const tabPanels = document.querySelectorAll('[data-panel]');

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');

        tabButtons.forEach((other) => {
          other.classList.toggle('tab-active', other === btn);
        });

        tabPanels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== target);
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolioDashboard);
  } else {
    initPortfolioDashboard();
  }
</script>

